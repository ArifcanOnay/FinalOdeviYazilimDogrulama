    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    <script>
        let currentPlaylistVideos = [];
        let ytPlayer = null;
        let currentVideoIndex = 0;
        let currentPlaylistId = null;
        let progressCheckInterval = null;
        let maxWatchedTime = 0;
        let videoDuration = 0;
        let lastCheckedTime = 0;

        const contactYoutubeLink = document.getElementById('contactYoutubeLink');
        if (contactYoutubeLink) {
            const forcedYoutubeUrl = 'https://www.youtube.com/@@5dakikadaingilizce';
            contactYoutubeLink.setAttribute('href', forcedYoutubeUrl);
            contactYoutubeLink.addEventListener('click', function (event) {
                event.preventDefault();
                window.open(forcedYoutubeUrl, '_blank', 'noopener,noreferrer');
            });
        }
        
        // Video progress tracking - LocalStorage ve Backend hibrit
        const VideoProgressManager = {
            currentUser: null,
            
            // Session'dan kullanıcı bilgisini al
            async checkUserSession() {
                try {
                    const response = await fetch('/Home/CheckSession', {
                        credentials: 'include'
                    });
                    const result = await response.json();
                    
                    if (result.success && result.data) {
                        this.currentUser = {
                            id: result.data.id,
                            name: result.data.name,
                            email: result.data.email
                        };
                        return true;
                    }
                    return false;
                } catch (error) {
                    console.log('Session check failed:', error);
                    return false;
                }
            },
            
            getProgress: function(playlistId, videoId) {
                // Kullanıcı giriş yapmamışsa 0 döndür
                if (!this.currentUser) {
                    return 0;
                }
                
                // Kullanıcıya özel key oluştur
                const userId = this.currentUser.id;
                const key = `video_progress_${userId}_${playlistId}_${videoId}`;
                const progress = parseFloat(localStorage.getItem(key)) || 0;
                
                // Debug için log
                if (progress > 0) {
                    console.log(`Progress okundu [User ${userId}]: Playlist ${playlistId}, Video ${videoId} = ${progress}%`);
                }
                
                return progress;
            },
            
            setProgress: async function(playlistId, videoId, percent, watchedSeconds = 0, totalDuration = 0) {
                // Kullanıcı giriş yapmamışsa işlem yapma
                if (!this.currentUser) {
                    console.warn('setProgress: Kullanıcı giriş yapmamış, progress kaydedilemiyor');
                    return;
                }
                
                // Kullanıcıya özel key oluştur
                const userId = this.currentUser.id;
                const key = `video_progress_${userId}_${playlistId}_${videoId}`;
                const normalizedPercent = Math.min(100, Math.max(0, percent));
                
                // Her zaman localStorage'a kaydet (cache olarak)
                localStorage.setItem(key, normalizedPercent.toFixed(2));
                
                // Backend'e de kaydet
                try {
                    console.log(`📤 Backend'e gönderiliyor: User=${userId}, Playlist=${playlistId}, Video=${videoId}, Progress=${normalizedPercent.toFixed(2)}%`);
                    
                    const apiUrl = '@ViewBag.ApiUrl' || window.location.origin;
                    const response = await fetch(`${apiUrl}/api/VideoProgress/update`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        credentials: 'include',
                        body: JSON.stringify({
                            userId: userId, // UserId'yi de gönder
                            playlistId: playlistId,
                            videoId: videoId,
                            izlenmeYuzdesi: normalizedPercent,
                            izlenenSaniye: watchedSeconds || Math.floor((normalizedPercent / 100) * totalDuration),
                            toplamSure: totalDuration || 600
                        })
                    });
                    
                    console.log(`📨 Backend response status: ${response.status} ${response.statusText}`);
                    
                    const result = await response.json();
                    console.log('📨 Backend response data:', result);
                    
                    if (result.success) {
                        console.log(`✅ Backend'e kaydedildi [User ${userId}]: Video ${videoId} = ${normalizedPercent.toFixed(2)}%`);
                    } else {
                        console.error('⚠️ Backend progress kaydı başarısız:', result.message);
                        
                        // Eğer session yoksa kullanıcıyı uyar (sadece bir kere)
                        if (result.requireLogin && !window.sessionExpiredWarned) {
                            console.error('❌ SESSION KAYBOLMUŞ! Kullanıcı tekrar giriş yapmalı!');
                            window.sessionExpiredWarned = true;
                            
                            // 3 saniye bekle, sonra yönlendir (böylece log'ları görebiliriz)
                            setTimeout(() => {
                                if (confirm('Oturumunuz sona erdi.\n\nGiriş sayfasına yönlendirilmek ister misiniz?')) {
                                    window.location.href = '/Home/Login';
                                }
                            }, 1000);
                        }
                    }
                } catch (error) {
                    console.error('❌ Backend kaydetme hatası:', error);
                    console.error('Error details:', error.message, error.stack);
                }
            },
            
            // Backend'den kullanıcının tüm progress'ini yükle
            async loadUserProgress(playlistId) {
                if (!this.currentUser) {
                    console.log('⚠️ loadUserProgress: Kullanıcı giriş yapmamış, atlanıyor');
                    return;
                }
                
                const userId = this.currentUser.id;
                
                try {
                    console.log(`📥 Backend'den progress yükleniyor [User ${userId}, Playlist ${playlistId}]...`);
                    const apiUrl = '@ViewBag.ApiUrl' || window.location.origin;
                    const response = await fetch(`${apiUrl}/api/VideoProgress/current-user/playlist/${playlistId}?userId=${userId}`, {
                        credentials: 'include'
                    });
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }
                    
                    const result = await response.json();
                    
                    if (result.success && result.data && result.data.length > 0) {
                        console.log(`✅ ${result.data.length} adet video progress'i yüklendi [Playlist ${playlistId}]`);
                        console.log('Backend data sample:', result.data[0]); // Debug için ilk kayda bak
                        
                        // Backend'den gelen verileri LocalStorage'a yaz (kullanıcıya özel)
                        result.data.forEach(progress => {
                            // Property isimlerini kontrol et (hem camelCase hem PascalCase)
                            const izlenmeYuzdesi = progress.izlenmeYuzdesi ?? progress.IzlenmeYuzdesi ?? 0;
                            const playlistId = progress.playlistId ?? progress.PlaylistId;
                            const videoId = progress.videoId ?? progress.VideoId;
                            const izlenenSaniye = progress.izlenenSaniye ?? progress.IzlenenSaniye ?? 0;
                            const toplamSure = progress.toplamSure ?? progress.ToplamSure ?? 0;
                            
                            const key = `video_progress_${userId}_${playlistId}_${videoId}`;
                            const progressValue = parseFloat(izlenmeYuzdesi).toFixed(2);
                            localStorage.setItem(key, progressValue);
                            console.log(`  📝 Video ${videoId}: ${progressValue}% (İzlenen: ${izlenenSaniye}s / ${toplamSure}s)`);
                        });
                        
                        console.log(`💾 LocalStorage'a ${result.data.length} kayıt yazıldı`);
                    } else {
                        console.log(`ℹ️ Playlist ${playlistId} için henüz progress kaydı yok`);
                    }
                } catch (error) {
                    console.error(`❌ Backend'den progress yüklenirken hata oluştu [Playlist ${playlistId}]:`, error);
                }
            },
            
            getPlaylistProgress: function(playlistId, videos) {
                if (!videos || videos.length === 0) return 0;
                
                let totalProgress = 0;
                videos.forEach(video => {
                    totalProgress += this.getProgress(playlistId, video.videoId);
                });
                
                return (totalProgress / videos.length).toFixed(1);
            },
            
            getCompletedCount: function(playlistId, videos) {
                if (!videos || videos.length === 0) return 0;
                
                return videos.filter(video => 
                    this.getProgress(playlistId, video.videoId) >= 95
                ).length;
            }
        };
        
        const playlists = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model ?? new List<OzgurSeyhanWebSitesi.Core.Dtos.PlaylistDtos.PlaylistWithVideosDto>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        @{
            var _videoDescMap = new Dictionary<string, string?>();
            System.Action<System.Collections.IEnumerable> _addToMap = null!;
            _addToMap = list => {
                if (list == null) return;
                foreach (OzgurSeyhanWebSitesi.Core.Dtos.YoutubeVideoDtos.YoutubeVideoDto v in list)
                    _videoDescMap[v.VideoId] = v.Aciklama;
            };
            _addToMap(ViewBag.IngilizceniGelistirecekPodcastler);
            _addToMap(ViewBag.IngilizceniGelistirecekYoutubeKanallari);
            _addToMap(ViewBag.IngilizceniGelistirecekDersler);
            _addToMap(ViewBag.IngilizceniGelistirecekTuyolar);
            _addToMap(ViewBag.GercekHayattanIngilizce);
        }
        const singleVideoDescriptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(_videoDescMap, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        
        console.log('📊 TOPLAM PLAYLIST SAYISI:', playlists.length);
        console.log('📋 TÜM PLAYLISTLER:', playlists);
        playlists.forEach((p, index) => {
            console.log(`  ${index + 1}. ID: ${p.id}, Başlık: ${p.baslik}, Video Sayısı: ${p.videos?.length || 0}, Kategori: ${p.kategori}`);
        });
        
        // Navbar'ı güncelle
        function updateNavbar(user) {
            const navContent = document.getElementById('userNavContent');
            
            if (user) {
                // Kullanıcı girişli - basit tasarım: sadece ad soyad ve çıkış
                navContent.innerHTML = `
                    <span style="color: white; margin-right: 15px; font-weight: 500;">
                        <i class="fas fa-user" style="margin-right: 8px;"></i>${user.name}
                    </span>
                    <a href="#" onclick="logout(event)" class="btn-nav btn-logout">
                        <i class="fas fa-sign-out-alt"></i>Çıkış Yap
                    </a>
                `;
            } else {
                // Kullanıcı girişli değil
                navContent.innerHTML = `
                    <a href="/Home/Login" class="btn-nav btn-login">
                        <i class="fas fa-sign-in-alt"></i>Giriş Yap
                    </a>
                    <a href="/Home/Register" class="btn-nav btn-register">
                        <i class="fas fa-user-plus"></i>Kayıt Ol
                    </a>
                `;
            }
        }
        
        // Çıkış yap fonksiyonu
        async function logout(event) {
            event.preventDefault();
            
            // ÖNEMLI: Çıkış yapıldığında mevcut kullanıcının localStorage verilerini temizle
            // Backend'de saklanan veriler korunuyor, sadece cache temizleniyor
            if (VideoProgressManager.currentUser) {
                const userId = VideoProgressManager.currentUser.id;
                const keysToRemove = [];
                
                // Bu kullanıcıya ait tüm progress key'lerini bul
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key && key.startsWith(`video_progress_${userId}_`)) {
                        keysToRemove.push(key);
                    }
                }
                
                // Bu kullanıcının verilerini temizle
                keysToRemove.forEach(key => localStorage.removeItem(key));
                console.log(`Çıkış yapıldı: ${keysToRemove.length} adet progress verisi temizlendi (backend'de korunuyor)`);
            }
            
            // Kullanıcı bilgisini temizle
            VideoProgressManager.currentUser = null;
            
            // UI'deki logout sayfasına git
            window.location.href = '/Home/Logout';
        }
        
        // Playlist kartlarındaki progress bar'ları güncelle
        function updateAllPlaylistProgress() {
            document.querySelectorAll('.playlist-progress').forEach(progressContainer => {
                const playlistId = parseInt(progressContainer.getAttribute('data-playlist-id'));
                const videoCount = parseInt(progressContainer.getAttribute('data-video-count'));
                
                const playlist = playlists.find(p => p.id === playlistId);
                if (!playlist || !playlist.videos) return;
                
                const overallProgress = VideoProgressManager.getPlaylistProgress(playlistId, playlist.videos);
                const completedCount = VideoProgressManager.getCompletedCount(playlistId, playlist.videos);
                
                // Progress bar'ı güncelle
                const progressBar = progressContainer.querySelector('.playlist-progress-bar');
                const progressText = progressContainer.querySelector('.playlist-progress-text');
                const completedText = progressContainer.querySelector('.playlist-completed-count');
                
                if (progressBar) progressBar.style.width = `${overallProgress}%`;
                if (progressText) progressText.textContent = `${overallProgress}%`;
                if (completedText) completedText.innerHTML = `<i class="fas fa-check-circle me-1"></i>${completedCount}/${videoCount} video tamamlandı`;
            });
        }
        
        // Sayfa yüklendiğinde kullanıcı session kontrolü yap
        document.addEventListener('DOMContentLoaded', async function() {
            console.log('🔄 Sayfa yükleniyor, kullanıcı session kontrol ediliyor...');
            
            await VideoProgressManager.checkUserSession();
            
            if (VideoProgressManager.currentUser) {
                const currentUserId = VideoProgressManager.currentUser.id;
                console.log(`✅ Kullanıcı giriş yapmış: ${VideoProgressManager.currentUser.name} (ID: ${currentUserId})`);
                
                // Diğer kullanıcılara ait localStorage verilerini temizle
                const keysToRemove = [];
                
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    // video_progress ile başlayan ama bu kullanıcıya ait olmayan key'leri bul
                    if (key && key.startsWith('video_progress_') && !key.startsWith(`video_progress_${currentUserId}_`)) {
                        keysToRemove.push(key);
                    }
                }
                
                // Diğer kullanıcıların verilerini temizle
                keysToRemove.forEach(key => localStorage.removeItem(key));
                if (keysToRemove.length > 0) {
                    console.log(`🧹 ${keysToRemove.length} adet başka kullanıcıya ait eski veri temizlendi`);
                }
                
                updateNavbar(VideoProgressManager.currentUser);
                
                // Tüm playlist'lerin progress'ini backend'den yükle
                console.log(`📥 ${playlists.length} adet playlist için backend'den progress yükleniyor...`);
                for (const playlist of playlists) {
                    await VideoProgressManager.loadUserProgress(playlist.id);
                }
                console.log('✅ Tüm progress verileri backend\'den başarıyla yüklendi!');
                
                // Progress bar'ları güncelle
                updateAllPlaylistProgress();
                console.log('🎨 Progress bar\'ları güncellendi');
            } else {
                console.log('ℹ️ Kullanıcı giriş yapmamış - Guest modu');
                updateNavbar(null);
                // Giriş yapmamış kullanıcılar için progress gösterme
                console.log('⚠️ Guest kullanıcılar video izleyemez, progress gösterilmiyor');
            }
        });
        
        async function openPlaylist(playlistId, playlistName) {
            // Kullanıcı giriş kontrolü - giriş yapmamışsa videoları izleyemez
            if (!VideoProgressManager.currentUser) {
                // Güzel bir uyarı modal'ı göster
                if (confirm('Videoları izlemek için giriş yapmanız gerekmektedir.\n\nGiriş sayfasına yönlendirilmek ister misiniz?')) {
                    window.location.href = '/Home/Login';
                }
                return;
            }
            
            // playlistId'yi number'a çevir (string olarak gelebilir)
            playlistId = parseInt(playlistId);
            currentPlaylistId = playlistId;
            document.getElementById('playlistModalTitle').textContent = playlistName;
            
            console.log('🎬 Opening playlist ID:', playlistId, '(type:', typeof playlistId, ')');
            console.log('📋 Searching in playlists:', playlists.map(p => ({ id: p.id, type: typeof p.id })));
            const playlist = playlists.find(p => p.id === playlistId);
            console.log('✅ Found playlist:', playlist);
            
            if(playlist && playlist.videos && playlist.videos.length > 0) {
                currentPlaylistVideos = playlist.videos;
                
                // Backend'den progress yükle
                await VideoProgressManager.loadUserProgress(playlistId);
                
                renderVideoList(playlist.videos);
                loadVideo(playlist.videos[0], 0);
                
                const modal = new bootstrap.Modal(document.getElementById('playlistModal'));
                modal.show();
            } else {
                console.error('❌ Playlist bulunamadı veya video yok', playlist);
                alert('Bu playlist\'te henüz video bulunmuyor.');
            }
        }
        
        function loadVideo(video, index) {
            currentVideoIndex = index;
            
            // Önceki player'ı temizle ve iframe'i yeniden oluştur
            if (ytPlayer) {
                ytPlayer.destroy();
                ytPlayer = null;
            }
            
            // Video player container'ı temizle ve yeni iframe ekle
            const container = document.getElementById('videoPlayerContainer');
            container.innerHTML = '<div id="videoPlayer"></div>';
            
            document.getElementById('currentVideoTitle').textContent = video.baslik;
            document.getElementById('currentVideoDescription').textContent = video.aciklama || 'Açıklama bulunmuyor';
            
            // Aktif videoyu vurgula
            document.querySelectorAll('.video-item').forEach((item, i) => {
                if (i === index) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            });
            
            // Daha önce izlenmiş süreyi al
            const savedProgress = VideoProgressManager.getProgress(currentPlaylistId, video.videoId);
            maxWatchedTime = 0;
            videoDuration = 0;
            
            // YouTube Player oluştur
            ytPlayer = new YT.Player('videoPlayer', {
                height: '100%',
                width: '100%',
                videoId: video.videoId,
                playerVars: {
                    'autoplay': 1,
                    'rel': 0,
                    'modestbranding': 1,
                    'controls': 2,  // Özel kontroller - seeking yasak
                    'disablekb': 1,  // Klavye kısayollarını devre dışı bırak
                    'fs': 1,
                    'iv_load_policy': 3
                },
                events: {
                    'onReady': onPlayerReady,
                    'onStateChange': onPlayerStateChange
                }
            });
        }
        
        function onPlayerReady(event) {
            console.log('Player hazır');
            
            // Video duration'ı al
            videoDuration = ytPlayer.getDuration();
            
            // Daha önce izlenmiş progress varsa, o noktaya kadar ileri alma izni ver
            const video = currentPlaylistVideos[currentVideoIndex];
            const savedProgress = VideoProgressManager.getProgress(currentPlaylistId, video.videoId);
            
            console.log(`Video: ${video.baslik}, Kaydedilmiş progress: ${savedProgress}%`);
            
            if (videoDuration > 0 && savedProgress > 0) {
                if (savedProgress < 95) {
                    // %95'ten az ise kaldığı yerden devam et
                    const startTime = (savedProgress / 100) * videoDuration;
                    maxWatchedTime = startTime;
                    console.log(`Kaldığı yerden devam ediliyor: ${Math.floor(startTime)} saniye (${Math.floor(savedProgress)}%)`);
                    
                    // Kullanıcıyı kaldığı yere götür
                    ytPlayer.seekTo(startTime, true);
                } else {
                    // Video tamamlanmış, baştan başlat ama max watched time'ı koru
                    maxWatchedTime = videoDuration;
                    console.log('Video tamamlanmış, baştan başlatılıyor');
                }
            }
            
            // Progress tracking başlat
            startRealVideoTracking();
        }
        
        function onPlayerStateChange(event) {
            // Video durumu değiştiğinde
            if (event.data == YT.PlayerState.PLAYING) {
                console.log('Video oynatılıyor');
                
                // Oynatma başladığında mevcut zamanı kontrol et
                const currentTime = ytPlayer.getCurrentTime();
                if (currentTime > maxWatchedTime + 1) {
                    console.warn('⚠️ SEEKING TESPİT EDİLDİ! Video geri alınıyor:', currentTime, '->', maxWatchedTime);
                    ytPlayer.seekTo(maxWatchedTime, true);
                    
                    // Alert yerine console.warn kullan - daha az rahatsız edici
                    if (!window.seekWarningShown) {
                        console.warn('⚠️ Videoyu ileri alamazsınız! Lütfen videoyu sırayla izleyiniz.');
                        window.seekWarningShown = true;
                        setTimeout(() => { window.seekWarningShown = false; }, 3000);
                    }
                }
                
                startRealVideoTracking();
            } else if (event.data == YT.PlayerState.PAUSED) {
                console.log('Video duraklatıldı');
                if (progressCheckInterval) {
                    clearInterval(progressCheckInterval);
                }
            } else if (event.data == YT.PlayerState.ENDED) {
                console.log('Video bitti');
                if (progressCheckInterval) {
                    clearInterval(progressCheckInterval);
                }
                // Video bittiğinde %100 yap
                const video = currentPlaylistVideos[currentVideoIndex];
                const duration = ytPlayer.getDuration();
                VideoProgressManager.setProgress(
                    currentPlaylistId, 
                    video.videoId, 
                    100,
                    Math.floor(duration),
                    Math.floor(duration)
                );
                updateVideoProgressUI(video.videoId);
                updatePlaylistProgressSummary();
            }
        }
        
        function startRealVideoTracking() {
            // Önceki interval'ı temizle
            if (progressCheckInterval) {
                clearInterval(progressCheckInterval);
            }
            
            const video = currentPlaylistVideos[currentVideoIndex];
            lastCheckedTime = 0;
            
            progressCheckInterval = setInterval(() => {
                if (!ytPlayer || !ytPlayer.getCurrentTime) return;
                
                try {
                    const currentTime = ytPlayer.getCurrentTime();
                    const duration = ytPlayer.getDuration();
                    const playerState = ytPlayer.getPlayerState();
                    
                    if (!duration || duration <= 0) return;
                    
                    // Eğer video oynatılıyorsa
                    if (playerState === YT.PlayerState.PLAYING) {
                        // Son kontrolden bu yana geçen süreyi hesapla
                        const timeDifference = currentTime - lastCheckedTime;
                        
                        // SADECE İLERİ ALMA KONTROLÜ (Geriye gitmeye izin ver)
                        // Kullanıcı izlemediği bir yere İLERİ gitmişse geri al
                        if (currentTime > maxWatchedTime + 2) {
                            console.warn('⛔ İLERİ ALMA ENGELLENDİ! CurrentTime:', currentTime, 'MaxWatched:', maxWatchedTime);
                            ytPlayer.seekTo(maxWatchedTime, true);
                            
                            // Alert yerine console.warn kullan
                            if (!window.seekWarningShown) {
                                console.warn('⚠️ Videoyu ileri alamazsınız! Geriye gidebilir, hızı değiştirebilirsiniz (2x hız önerilir)');
                                window.seekWarningShown = true;
                                setTimeout(() => { window.seekWarningShown = false; }, 3000);
                            }
                            return;
                        }
                        
                        lastCheckedTime = currentTime;
                    }
                    
                    // Maksimum izlenen zamanı güncelle
                    if (currentTime > maxWatchedTime) {
                        maxWatchedTime = currentTime;
                    }
                    
                    // Progress hesapla
                    const progress = (maxWatchedTime / duration) * 100;
                    
                    // Progress'i kaydet ve UI'ı güncelle (gerçek süreleri gönder)
                    VideoProgressManager.setProgress(
                        currentPlaylistId, 
                        video.videoId, 
                        progress,
                        Math.floor(maxWatchedTime),
                        Math.floor(duration)
                    );
                    updateVideoProgressUI(video.videoId);
                    updatePlaylistProgressSummary();
                    
                    console.log(`Progress: ${Math.floor(progress)}% (${Math.floor(maxWatchedTime)}/${Math.floor(duration)} saniye)`);
                } catch (error) {
                    console.error('Tracking hatası:', error);
                }
            }, 500); // Her yarım saniyede kontrol et - daha hızlı tepki
        }
        
        function updateVideoProgressUI(videoId) {
            const progressBar = document.querySelector(`[data-video-id="${videoId}"] .video-progress-fill`);
            const progressText = document.querySelector(`[data-video-id="${videoId}"] .video-progress-percent`);
            
            if (progressBar && progressText) {
                const progress = VideoProgressManager.getProgress(currentPlaylistId, videoId);
                progressBar.style.width = progress + '%';
                progressText.textContent = Math.floor(progress) + '%';
            }
        }
        
        function updatePlaylistProgressSummary() {
            const overallProgress = VideoProgressManager.getPlaylistProgress(currentPlaylistId, currentPlaylistVideos);
            const completedCount = VideoProgressManager.getCompletedCount(currentPlaylistId, currentPlaylistVideos);
            
            const progressFill = document.querySelector('.playlist-overall-fill');
            const statsCompleted = document.querySelector('.stats-completed');
            const statsPercent = document.querySelector('.stats-percent');
            
            if (progressFill) {
                progressFill.style.width = overallProgress + '%';
            }
            
            if (statsCompleted) {
                statsCompleted.textContent = `${completedCount}/${currentPlaylistVideos.length} Video Tamamlandı`;
            }
            
            if (statsPercent) {
                statsPercent.textContent = `%${overallProgress} Tamamlandı`;
            }
        }
        
        function renderVideoList(videos) {
            const container = document.getElementById('videoListContainer');
            container.innerHTML = '';
            
            // Playlist progress summary ekle
            const progressSummary = document.createElement('div');
            progressSummary.className = 'playlist-progress-summary';
            const overallProgress = VideoProgressManager.getPlaylistProgress(currentPlaylistId, videos);
            const completedCount = VideoProgressManager.getCompletedCount(currentPlaylistId, videos);
            
            progressSummary.innerHTML = `
                <div class="playlist-progress-title">
                    <i class="fas fa-chart-line me-2"></i>Kurs İlerlemeniz
                </div>
                <div class="playlist-overall-progress">
                    <div class="playlist-overall-fill" style="width: ${overallProgress}%"></div>
                </div>
                <div class="playlist-stats">
                    <span class="playlist-stats-item stats-completed">
                        <i class="fas fa-check-circle"></i>
                        ${completedCount}/${videos.length} Video Tamamlandı
                    </span>
                    <span class="playlist-stats-item stats-percent">
                        <i class="fas fa-percentage"></i>
                        %${overallProgress} Tamamlandı
                    </span>
                </div>
            `;
            
            container.appendChild(progressSummary);
            
            videos.forEach((video, index) => {
                const videoItem = document.createElement('div');
                videoItem.className = 'video-item';
                videoItem.setAttribute('data-video-id', video.videoId);
                if (index === 0) videoItem.classList.add('active');
                videoItem.onclick = () => loadVideo(video, index);
                
                const progress = VideoProgressManager.getProgress(currentPlaylistId, video.videoId);
                const isCompleted = progress >= 95;
                
                videoItem.innerHTML = `
                    <img src="https://img.youtube.com/vi/${video.videoId}/mqdefault.jpg" 
                         alt="${video.baslik}" class="video-thumbnail-small">
                    <div class="video-info">
                        <div class="video-title">${index + 1}. ${video.baslik}</div>
                        <div class="video-duration">
                            <i class="fas fa-play-circle me-1"></i>Video ${index + 1}
                        </div>
                        <div class="video-progress-container">
                            <div class="video-progress-bar">
                                <div class="video-progress-fill" style="width: ${progress}%"></div>
                            </div>
                            <div class="video-progress-text">
                                <span class="video-progress-percent">${Math.floor(progress)}%</span>
                                ${isCompleted ? '<span class="video-completed-badge"><i class="fas fa-check"></i> Tamamlandı</span>' : ''}
                            </div>
                        </div>
                    </div>
                `;
                
                container.appendChild(videoItem);
            });
        }
        
        // Modal kapandığında videoyu durdur ve progress tracking'i durdur
        document.getElementById('playlistModal').addEventListener('hidden.bs.modal', function () {
            document.getElementById('videoPlayer').src = '';
            if (progressCheckInterval) {
                clearInterval(progressCheckInterval);
                progressCheckInterval = null;
            }
        });
        
        // Tek video açma fonksiyonu (İngilizce Konuşma Tüyoları için)
        function openSingleVideo(videoId, videoTitle) {
            currentPlaylistId = 'single_video'; // Tek video için özel ID
            document.getElementById('playlistModalTitle').textContent = videoTitle;
            
            // Video player container'ı temizle ve iframe oluştur
