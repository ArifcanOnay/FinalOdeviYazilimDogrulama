                container.innerHTML = '<div id="videoPlayer"></div>';
                
                // Layout'u geri getir
                document.querySelector('.video-main-section').classList.remove('col-lg-12');
                document.querySelector('.video-main-section').classList.add('col-lg-8');
                document.querySelector('.video-sidebar').style.display = 'block';
                
                // Event listener'ı kaldır
                document.getElementById('playlistModal').removeEventListener('hidden.bs.modal', resetLayout);
