    <!-- Oyun Kosesi Bolumu -->
    <section class="flow-puzzle-section" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 80px 0; color: white; position: relative; overflow: hidden;">
        <div class="container" style="position: relative; z-index: 1;">
            <h2 class="section-title" style="font-size: 3rem; font-weight: 800; text-align: center; margin-bottom: 1rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">
                <i class="fas fa-bolt me-2"></i>Oyun Kosesi
            </h2>
            <p class="section-subtitle" style="text-align: center; font-size: 1.3rem; margin-bottom: 3rem; opacity: 0.95;">
                Zincir mantigiyla ogrenirken eglenecegin tum oyunlar tek bir kose de.
            </p>
            
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="flow-puzzle-card" style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); border-radius: 25px; padding: 50px; text-align: center; box-shadow: 0 15px 50px rgba(0,0,0,0.3); border: 2px solid rgba(255, 255, 255, 0.2);">
                        <div class="puzzle-icon mb-4">
                            <i class="fas fa-link fa-5x" style="color: #ffd700; opacity: 0.9;"></i>
                        </div>
                        <h3 style="font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem;">Oyun Kosesi: surukle, eslestir, tamamla!</h3>
                        <p style="font-size: 1.1rem; margin-bottom: 2rem; line-height: 1.8;">
                            🎯 <strong>Zincir Eslestirme:</strong> Kartlari dogru sirayla birlestir, hizi ve dikkati ayni anda gelistir.<br>
                            ⚡ <strong>Fiil Oyunu:</strong> Tense, modal ve soru yapilarinda cumnenin akisini guclendir.<br>
                            🧩 <strong>Relative Clause Oyunu:</strong> Who, which, that, where, when, whose kaliplarini pratik et.<br>
                            🧱 <strong>Uzun Tamlama Oyunu:</strong> Bas isim + tamlayan + detay parcasiyla uzun ifade kurmayi pekistir.<br>
                            📚 <strong>Kademeli Akis:</strong> Sayfali yapi ile duzenli tekrar yap, ilerlemeni net gor.<br>
                            <br>
                            Her turda dogru zinciri kur, hizini artir ve Ingilizce cumle kurma becerini kalici hale getir.
                        </p>
                        <a href="@Url.Action("FlowPuzzleGame", "Home")" class="btn" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; font-size: 1.3rem; font-weight: bold; padding: 18px 50px; border-radius: 50px; text-decoration: none; box-shadow: 0 10px 30px rgba(245, 87, 108, 0.4); transition: all 0.3s ease; display: inline-block;">
                            <i class="fas fa-gamepad me-2"></i>Fiil Oyunu
                        </a>
                        <a href="@Url.Action("RelativeClauseGame", "Home")" class="btn ms-2" style="background: linear-gradient(135deg, #20bf6b 0%, #0fb9b1 100%); color: white; font-size: 1.1rem; font-weight: bold; padding: 14px 30px; border-radius: 50px; text-decoration: none; box-shadow: 0 10px 24px rgba(15, 185, 177, 0.35); transition: all 0.3s ease; display: inline-block;">
