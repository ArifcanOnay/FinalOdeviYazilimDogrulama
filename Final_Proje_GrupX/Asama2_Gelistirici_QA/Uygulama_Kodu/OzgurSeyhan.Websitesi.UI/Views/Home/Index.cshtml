        // Özel Ders detay modal
        const ozelDersler = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.OzelDersler ?? new List<OzgurSeyhanWebSitesi.Core.Dtos.OzelDersDtos.OzelDersDto>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        
        function openOzelDersDetail(dersId, kurSeviyesi) {
            console.log('Opening ders ID:', dersId);
            const ders = ozelDersler.find(d => d.id === dersId);
            console.log('Found ders:', ders);
            
            if(!ders) {
                alert('Ders bilgisi bulunamadı.');
                return;
            }

            // Modal başlığı
            document.getElementById('ozelDersModalTitle').textContent = ders.kurSeviyesi;
            
            // Detaylar
            document.getElementById('dersAciklama').textContent = ders.aciklama;
            
            // YouTube videosu
            const videoContainer = document.getElementById('dersVideoContainer');
            if(ders.youtubeVideoUrl) {
                const videoId = extractYouTubeVideoId(ders.youtubeVideoUrl);
                if(videoId) {
                    videoContainer.innerHTML = `
                        <iframe width="100%" height="315" 
                            src="https://www.youtube.com/embed/${videoId}" 
                            frameborder="0" 
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                            allowfullscreen>
                        </iframe>
                    `;
                } else {
                    videoContainer.innerHTML = '<p class="text-muted">Video yüklenemedi</p>';
                }
            } else {
                videoContainer.innerHTML = '<p class="text-muted">Bu kurs için henüz tanıtım videosu eklenmemiş</p>';
            }
            
            // Modal'ı aç
            const modal = new bootstrap.Modal(document.getElementById('ozelDersModal'));
            modal.show();
        }

        function extractYouTubeVideoId(url) {
            if(!url) return null;
            
            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
            const match = url.match(regExp);
            
            return (match && match[2].length === 11) ? match[2] : null;
        }

