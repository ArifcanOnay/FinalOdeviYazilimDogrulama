    function isTurkishTailCompatible(tailText, preposition, verbPack) {
        const text = (tailText || '').toLowerCase().trim();
        const prep = (preposition || '').toLowerCase().trim();

        if (!text || !prep || !verbPack.allowedPrepositions.has(prep)) {
            return false;
        }

        if (prep === 'to') {
            return !text.includes('hakkında') && !text.includes(' ile') && !text.includes(' için')
                && !text.includes(' yüzünden') && !text.includes(' olmadan') && !text.includes(' sonra')
                && !text.includes(' önce');
        }

        if (prep === 'in' || prep === 'at') {
            return !text.includes('hakkında') && !text.includes(' ile') && !text.includes(' için')
                && (text.endsWith('da') || text.endsWith('de') || text.endsWith('ta') || text.endsWith('te') || text.includes('daki ') || text.includes('deki '));
        }

        if (prep === 'with') {
            return text.includes(' ile') || text.endsWith('ile') || text.endsWith('la') || text.endsWith('le');
        }

        if (prep === 'without') {
            return text.includes('olmadan');
        }

        if (prep === 'about') {
            return text.includes('hakkında');
        }

        if (prep === 'for') {
            return text.includes(' için');
        }

        return false;
    }

    // ========== VERB MODE SPECIAL HANDLING ==========
    function buildVerbHeadPairs() {
        return rawSentences.map((s, idx) => ({
            id: idx + 1,
            en: s.preposition,  // "I go", "I don't go", etc.
            tr: '',
            tenseKey: 'verbTense' + idx
        }));
    }

    function buildVerbTailPairs(sentencesList) {
        const sentiList = sentencesList || rawSentences;
        const uniqueTails = [];
        const seenTailTexts = new Map(); // text -> id mapping
        let tailId = 1;
        
        sentiList.forEach((s) => {
            const tailText = (s.detSing + ' ' + s.detPlural).trim();
            
            if (!seenTailTexts.has(tailText)) {
                seenTailTexts.set(tailText, tailId);
                uniqueTails.push({
                    id: tailId,
                    preposition: s.preposition,
                    en: tailText,
                    tr: ''
                });
                tailId++;
            }
        });
        
        return uniqueTails;
    }

    function buildVerbFinalSentences(sentencesList) {
        const sentiList = sentencesList || rawSentences;
        const uniqueTails = buildVerbTailPairs(sentiList);
        const tailTextToId = new Map();
        uniqueTails.forEach(t => tailTextToId.set(t.en, t.id));
        
        return sentiList.map((s, idx) => {
            const tailText = (s.detSing + ' ' + s.detPlural).trim();
            const tailId = tailTextToId.get(tailText);
            
            return {
                id: idx + 1,
                tailId: tailId,
                headEn: s.preposition,
                headTr: '',
                tailEn: tailText,
                tailTr: '',
                finalEn: (s.preposition + ' ' + tailText).trim(),
                finalTr: s.trSing
            };
        });
    }

    function buildVerbSentenceChains() {
        const ordered = [...rawSentences].sort((a, b) => (a.displayOrder || 0) - (b.displayOrder || 0));

        let startIndex = 0;
        let itemCount = 3;

        if (currentTenseId === WH_TENSE_ID) {
            startIndex = 21;
            itemCount = 7;
        } else {
            startIndex = currentTenseId * 3;
        }

        let filteredSentences = ordered.slice(startIndex, startIndex + itemCount);

        if (currentTenseId === WH_TENSE_ID && currentWhGroup === 'negative') {
            filteredSentences = buildNegativeWhSentences(filteredSentences);
        }

        if (currentTenseId === WH_TENSE_ID) {
            const whoExample = WHO_W_QUESTION_BY_VERB[(currentNounEn || '').toLowerCase()];
            if (whoExample && filteredSentences.length > 0) {
                filteredSentences[0] = {
                    ...filteredSentences[0],
                    preposition: currentWhGroup === 'negative' ? makeNegativeQuestionHead(whoExample.head) : whoExample.head,
                    detSing: whoExample.tail,
                    detPlural: '',
                    trSing: currentWhGroup === 'negative' ? makeNegativeTurkishWh(whoExample.tr) : whoExample.tr,
                    trPlural: currentWhGroup === 'negative' ? makeNegativeTurkishWh(whoExample.tr) : whoExample.tr
                };
            }
        }

        return buildVerbFinalSentences(filteredSentences);
    }

