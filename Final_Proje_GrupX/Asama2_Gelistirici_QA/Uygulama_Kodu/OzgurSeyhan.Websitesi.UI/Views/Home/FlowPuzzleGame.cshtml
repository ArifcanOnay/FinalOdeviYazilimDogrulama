                { en: `Might I ${base} tomorrow?`, tr: `Yarin ${base} yapabilir miyim?` },
                { en: `Must I ${base} this week?`, tr: `Bu hafta ${base} yapmak zorunda miyim?` }
            ],
            wh: [
                { en: `How can I ${base} better?`, tr: `${capitalized} daha iyi nasil yapabilirim?` },
                { en: `Where could I ${base}?`, tr: `${capitalized} nerede yapabilirdim?` },
                { en: `Why would I ${base}?`, tr: `Neden ${base} yapardim?` },
                { en: `What should I ${base} first?`, tr: `Ilk olarak neyi ${base} yapmaliyim?` },
                { en: `When may I ${base}?`, tr: `${base} ne zaman yapabilirim?` },
                { en: `What might I ${base}?`, tr: `Neyi ${base} yapabilirim?` },
                { en: `Why must I ${base}?`, tr: `Neden ${base} yapmak zorundayim?` }
            ]
        };
    }

    function getModalExamplesForCurrentVerb() {
        const key = (currentNounEn || '').toLowerCase();
        return MODAL_MATCHING_BY_VERB[key] || getFallbackModalExamples();
    }

    function splitModalSentenceForChain(enSentence) {
        const sentence = (enSentence || '').trim();
        if (!sentence) {
            return { head: '', tail: '' };
        }

        const cleaned = sentence.replace(/[?.!]$/, '');
        const tokens = cleaned.split(' ').filter(Boolean);
        if (tokens.length < 3) {
            return { head: cleaned, tail: '' };
        }

        const first = tokens[0].toLowerCase();
        const whWords = new Set(['what', 'where', 'when', 'why', 'how', 'who', 'which']);
        const modalStarters = new Set(['can', 'could', 'would', 'should', 'may', 'might', 'must']);
        let headLength = 2;

        if (whWords.has(first)) {
            headLength = 3;
        } else if (modalStarters.has(first)) {
            headLength = 2;
        } else {
            headLength = 2;
        }

        if (tokens.length <= headLength) {
            headLength = Math.max(1, tokens.length - 1);
        }

        return {
            head: tokens.slice(0, headLength).join(' '),
            tail: tokens.slice(headLength).join(' ')
        };
    }

    function buildModalSentenceChains() {
        const modalData = getModalExamplesForCurrentVerb();
        let items = (modalData[currentModalGroup] || []).slice(0, 7);

        if (currentModalGroup === 'wh') {
            const key = (currentNounEn || '').toLowerCase();
            const whoItem = WHO_MODAL_WH_BY_VERB[key];
            const hasWhoSentence = items.some(item => /^who\b/i.test((item.en || '').trim()));
            if (whoItem && !hasWhoSentence) {
                items = [whoItem, ...items.slice(1)];
            }
        }

        const tailIdMap = new Map();
        let nextTailId = 1;

        return items.map((item, idx) => {
            const parts = splitModalSentenceForChain(item.en);
            if (!tailIdMap.has(parts.tail)) {
                tailIdMap.set(parts.tail, nextTailId++);
            }

            return {
                id: idx + 1,
                tailId: tailIdMap.get(parts.tail),
                headEn: parts.head,
                headTr: '',
                tailEn: parts.tail,
                tailTr: '',
                finalEn: item.en,
                finalTr: item.tr || ''
            };
        });
    }

    function buildModalBoardOrder(chainList) {
        const uniqueTailsMap = new Map();
        chainList.forEach(chain => {
            if (!uniqueTailsMap.has(chain.tailEn)) {
                uniqueTailsMap.set(chain.tailEn, {
                    id: chain.tailId,
                    en: chain.tailEn,
                    tr: ''
                });
            }
        });

        const uniqueTails = Array.from(uniqueTailsMap.values());
        return {
            headEn: chainList.map(item => ({ id: item.id, text: item.headEn })),
            headTr: chainList.map(item => ({ id: item.id, text: '' })),
            tailEn: shuffle(uniqueTails.map(item => ({ id: item.id, text: item.en }))),
            tailTr: shuffle(uniqueTails.map(item => ({ id: item.id, text: '' }))),
            finalEn: shuffle(chainList.map(item => ({ id: item.id, text: item.finalEn }))),
            finalTr: shuffle(chainList.map(item => ({ id: item.id, text: item.finalTr })))
        };
    }

    function setVerbPanelsVisibility(showGamePanels) {
        const modulesGrid = document.querySelector('.modules-grid');
        const modalsArea = document.getElementById('modalsArea');

        if (modulesGrid) {
            modulesGrid.style.display = showGamePanels ? 'grid' : 'none';
        }

        if (modalsArea) {
            modalsArea.classList.toggle('hidden', showGamePanels);
        }
    }

    function buildVerbBoardOrder(chainList) {
        // Extract unique tails from the filtered chainList
        const uniqueTailsMap = new Map();
        chainList.forEach(chain => {
            if (!uniqueTailsMap.has(chain.tailEn)) {
                uniqueTailsMap.set(chain.tailEn, {
                    id: chain.tailId,
                    en: chain.tailEn,
                    tr: ''
                });
            }
        });
        const uniqueTails = Array.from(uniqueTailsMap.values());
        
        return {
            headEn: chainList.map(item => ({ id: item.id, text: item.headEn })),
            headTr: chainList.map(item => ({ id: item.id, text: '' })),
            tailEn: shuffle(uniqueTails.map(item => ({ id: item.id, text: item.en }))),
            tailTr: shuffle(uniqueTails.map(item => ({ id: item.id, text: '' }))),
            finalEn: shuffle(chainList.map(item => ({ id: item.id, text: item.finalEn }))),
            finalTr: shuffle(chainList.map(item => ({ id: item.id, text: item.finalTr })))
        };
    }
    // ========== END VERB MODE SPECIAL HANDLING ==========

    function buildHeadPairs() {
        const verb = getSingleVerbPack();
        return [
            { id: 1, tenseKey: 'futurePositive', en: `I will ${verb.enBase} tomorrow.`, tr: `Ben yarın ${verb.trFuture}.` },
            { id: 2, tenseKey: 'futureNegative', en: `I will not ${verb.enBase} tomorrow.`, tr: `Ben yarın ${verb.trFutureNegative}.` },
            { id: 3, tenseKey: 'futureQuestion', en: `Will I ${verb.enBase} tomorrow?`, tr: `Ben yarın ${verb.trFutureQuestion}?` },
            { id: 4, tenseKey: 'simplePastPositive', en: `I ${verb.enPast} yesterday.`, tr: `Ben dün ${verb.trSimplePast}.` },
            { id: 5, tenseKey: 'simplePastNegative', en: `I did not ${verb.enBase} yesterday.`, tr: `Ben dün ${verb.trSimplePastNegative}.` },
            { id: 6, tenseKey: 'simplePastQuestion', en: `Did I ${verb.enBase} yesterday?`, tr: `Ben dün ${verb.trSimplePastQuestion}?` },
            { id: 7, tenseKey: 'presentPerfectPositive', en: `I have ${verb.enPastPart} before.`, tr: `Ben daha önce ${verb.trPresentPerfect}.` },
            { id: 8, tenseKey: 'presentPerfectNegative', en: `I have not ${verb.enPastPart} before.`, tr: `Ben daha önce ${verb.trPresentPerfectNegative}.` },
            { id: 9, tenseKey: 'presentPerfectQuestion', en: `Have I ${verb.enPastPart} before?`, tr: `Ben daha önce ${verb.trPresentPerfectQuestion}?` },
            { id: 10, tenseKey: 'pastPerfectPositive', en: `I had ${verb.enPastPart} before.`, tr: `Ben daha önce ${verb.trPastPerfect}.` },
            { id: 11, tenseKey: 'pastPerfectNegative', en: `I had not ${verb.enPastPart} before.`, tr: `Ben daha önce ${verb.trPastPerfectNegative}.` },
            { id: 12, tenseKey: 'pastPerfectQuestion', en: `Had I ${verb.enPastPart} before?`, tr: `Ben daha önce ${verb.trPastPerfectQuestion}?` },
            { id: 13, tenseKey: 'pastContinuousPositive', en: `I was ${verb.enGerund} yesterday.`, tr: `Ben dün ${verb.trPastContinuous}.` },
            { id: 14, tenseKey: 'pastContinuousNegative', en: `I was not ${verb.enGerund} yesterday.`, tr: `Ben dün ${verb.trPastContinuousNegative}.` },
            { id: 15, tenseKey: 'pastContinuousQuestion', en: `Was I ${verb.enGerund} yesterday?`, tr: `Ben dün ${verb.trPastContinuousQuestion}?` }
        ];
    }

    function buildTailPairs(currentMode) {
        const keyDet = currentMode === 'plural' ? 'detPlural' : 'detSing';
        const keyNoun = currentMode === 'plural' ? 'nounPlural' : 'nounSing';
        const keyTr = currentMode === 'plural' ? 'trPlural' : 'trSing';
        const maxTotal = 5;
        const verbPack = getSingleVerbPack();
        const eligibleSentences = rawSentences.filter(sentence => {
            const prep = (sentence.preposition || '').toLowerCase().trim();
            const tailText = currentMode === 'plural' ? sentence.trPlural : sentence.trSing;
            return isTurkishTailCompatible(tailText, prep, verbPack);
        });
        const sentencePool = eligibleSentences.length > 0 ? eligibleSentences : rawSentences;

        const groupedByPreposition = new Map();
        sentencePool.forEach(sentence => {
            const prepKey = (sentence.preposition || '').toLowerCase().trim();
            if (!prepKey) {
                return;
            }

            if (!groupedByPreposition.has(prepKey)) {
                groupedByPreposition.set(prepKey, []);
            }

            groupedByPreposition.get(prepKey).push(sentence);
        });

        const selectedSentences = [];
        const prepKeys = shuffle(Array.from(groupedByPreposition.keys()));

        prepKeys.forEach(prepKey => {
            if (selectedSentences.length >= maxTotal) {
                return;
            }

            const bucket = groupedByPreposition.get(prepKey) || [];
            if (bucket.length > 0) {
                selectedSentences.push(bucket[0]);
            }
        });

        const sourceSentences = selectedSentences.length > 0
            ? selectedSentences
            : sentencePool.slice(0, maxTotal);

        return sourceSentences.map((sentence, index) => {
            const determiner = sentence[keyDet] && sentence[keyDet] !== '-' ? `${sentence[keyDet]} ` : '';
            return {
                id: index + 1,
                preposition: (sentence.preposition || '').toLowerCase(),
                en: `${sentence.preposition} ${determiner}${sentence[keyNoun]}`.replace(/\s+/g, ' ').trim(),
                tr: sentence[keyTr]
            };
        });
    }

    function cleanTailForTr(text) {
        return (text || '').replace(/\s+/g, ' ').trim();
    }

    function getTurkishPredicateForTail(tenseKey, tail, verb) {
        const prep = (tail.preposition || '').toLowerCase().trim();
        const category = getNounCategory(currentNounEn);

        if (category === 'people' && prep === 'to') {
            switch (tenseKey) {
                case 'futurePositive': return 'hitap edeceğim';
                case 'futureNegative': return 'hitap etmeyeceğim';
                case 'futureQuestion': return 'hitap edecek miyim';
                case 'simplePastPositive': return 'hitap ettim';
                case 'simplePastNegative': return 'hitap etmedim';
                case 'simplePastQuestion': return 'hitap ettim mi';
                case 'presentPerfectPositive': return 'hitap ettim';
                case 'presentPerfectNegative': return 'hitap etmedim';
                case 'presentPerfectQuestion': return 'hitap ettim mi';
                case 'pastPerfectPositive': return 'hitap etmiştim';
                case 'pastPerfectNegative': return 'hitap etmemiştim';
                case 'pastPerfectQuestion': return 'hitap etmiş miydim';
                case 'pastContinuousPositive': return 'hitap ediyordum';
                case 'pastContinuousNegative': return 'hitap etmiyordum';
                case 'pastContinuousQuestion': return 'hitap ediyor muydum';
                default: return verb.trSimplePast;
            }
        }

        switch (tenseKey) {
            case 'futurePositive': return verb.trFuture;
            case 'futureNegative': return verb.trFutureNegative;
            case 'futureQuestion': return verb.trFutureQuestion;
            case 'simplePastPositive': return verb.trSimplePast;
            case 'simplePastNegative': return verb.trSimplePastNegative;
            case 'simplePastQuestion': return verb.trSimplePastQuestion;
            case 'presentPerfectPositive': return verb.trPresentPerfect;
            case 'presentPerfectNegative': return verb.trPresentPerfectNegative;
            case 'presentPerfectQuestion': return verb.trPresentPerfectQuestion;
            case 'pastPerfectPositive': return verb.trPastPerfect;
            case 'pastPerfectNegative': return verb.trPastPerfectNegative;
            case 'pastPerfectQuestion': return verb.trPastPerfectQuestion;
            case 'pastContinuousPositive': return verb.trPastContinuous;
            case 'pastContinuousNegative': return verb.trPastContinuousNegative;
            case 'pastContinuousQuestion': return verb.trPastContinuousQuestion;
            default: return verb.trSimplePast;
        }
    }

    function buildFinalSentence(head, tail) {
        const verb = getSingleVerbPack();
        const tailEn = (tail.en || '').trim();
        const tailTr = cleanTailForTr(tail.tr);
        const trPredicate = getTurkishPredicateForTail(head.tenseKey, tail, verb);

        switch (head.tenseKey) {
            case 'futurePositive':
                return {
                    en: `I will ${verb.enBase} ${tailEn} tomorrow.`,
                    tr: `Ben yarın ${tailTr} ${trPredicate}.`
                };
            case 'futureNegative':
                return {
                    en: `I will not ${verb.enBase} ${tailEn} tomorrow.`,
                    tr: `Ben yarın ${tailTr} ${trPredicate}.`
                };
            case 'futureQuestion':
                return {
                    en: `Will I ${verb.enBase} ${tailEn} tomorrow?`,
                    tr: `Ben yarın ${tailTr} ${trPredicate}?`
                };
            case 'simplePastPositive':
                return {
                    en: `I ${verb.enPast} ${tailEn} yesterday.`,
                    tr: `Ben dün ${tailTr} ${trPredicate}.`
                };
            case 'simplePastNegative':
                return {
                    en: `I did not ${verb.enBase} ${tailEn} yesterday.`,
                    tr: `Ben dün ${tailTr} ${trPredicate}.`
                };
            case 'simplePastQuestion':
                return {
                    en: `Did I ${verb.enBase} ${tailEn} yesterday?`,
                    tr: `Ben dün ${tailTr} ${trPredicate}?`
                };
            case 'presentPerfectPositive':
                return {
                    en: `I have ${verb.enPastPart} ${tailEn} before.`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}.`
                };
            case 'presentPerfectNegative':
                return {
                    en: `I have not ${verb.enPastPart} ${tailEn} before.`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}.`
                };
            case 'presentPerfectQuestion':
                return {
                    en: `Have I ${verb.enPastPart} ${tailEn} before?`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}?`
                };
            case 'pastPerfectPositive':
                return {
                    en: `I had ${verb.enPastPart} ${tailEn} before.`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}.`
                };
            case 'pastPerfectNegative':
                return {
                    en: `I had not ${verb.enPastPart} ${tailEn} before.`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}.`
                };
            case 'pastPerfectQuestion':
                return {
                    en: `Had I ${verb.enPastPart} ${tailEn} before?`,
                    tr: `Ben daha önce ${tailTr} ${trPredicate}?`
                };
            case 'pastContinuousPositive':
                return {
                    en: `I was ${verb.enGerund} ${tailEn} yesterday.`,
                    tr: `Ben dün ${tailTr} ${trPredicate}.`
                };
            case 'pastContinuousNegative':
                return {
                    en: `I was not ${verb.enGerund} ${tailEn} yesterday.`,
                    tr: `Ben dün ${tailTr} ${trPredicate}.`
                };
            case 'pastContinuousQuestion':
                return {
                    en: `Was I ${verb.enGerund} ${tailEn} yesterday?`,
                    tr: `Ben dün ${tailTr} ${trPredicate}?`
                };
            default:
                return {
                    en: `${head.en} ${tail.en}.`,
                    tr: `${head.tr} ${tail.tr}.`
                };
        }
    }

    function buildSentenceChains(currentMode) {
        const heads = buildHeadPairs();
        const tails = buildTailPairs(currentMode);

        if (!tails.length) {
            return [];
        }

        const total = heads.length;

        return heads.slice(0, total).map((head, index) => {
            const tail = tails[index % tails.length];
            const finalSentence = buildFinalSentence(head, tail);

            return {
                id: index + 1,
                tailId: tail.id,
                headEn: head.en,
                headTr: head.tr,
                tailEn: tail.en,
                tailTr: tail.tr,
                finalEn: finalSentence.en,
                finalTr: finalSentence.tr
            };
        });
    }

    function makeBoardOrder(chainList) {
        const uniqueTails = [];
        const seenTailIds = new Set();

        chainList.forEach(item => {
            if (seenTailIds.has(item.tailId)) {
                return;
            }

            seenTailIds.add(item.tailId);
            uniqueTails.push({ id: item.tailId, en: item.tailEn, tr: item.tailTr });
        });

        return {
            headEn: shuffle(chainList.map(item => ({ id: item.id, text: item.headEn }))),
            headTr: shuffle(chainList.map(item => ({ id: item.id, text: item.headTr }))),
            tailEn: shuffle(uniqueTails.map(item => ({ id: item.id, text: item.en }))),
            tailTr: shuffle(uniqueTails.map(item => ({ id: item.id, text: item.tr }))),
            finalEn: shuffle(chainList.map(item => ({ id: item.id, text: item.finalEn }))),
            finalTr: shuffle(chainList.map(item => ({ id: item.id, text: item.finalTr })))
        };
    }

    function createChainState(total) {
        return {
            total,
            completedIds: new Set(),
            activeChainId: null,
            passedKeys: new Set(),
            pointerId: null,
            pointerPosition: null,
            chainCompletedNow: false
        };
    }

    function getActiveChain() {
        return chains.find(item => item.id === chainState.activeChainId) || null;
    }

    function getExpectedItemId(key) {
        const activeChain = getActiveChain();
        if (!activeChain) {
            return null;
        }

        if (key === 'tailEn' || key === 'tailTr') {
            return activeChain.tailId;
        }

        return activeChain.id;
    }

    function renderColumn(columnId, key, langClass) {
        const column = document.getElementById(columnId);
        if (!column) {
            return;
        }

        column.querySelectorAll('.pair-item').forEach(item => item.remove());

        boardOrder[key].forEach(item => {
            const isTailColumn = key === 'tailEn' || key === 'tailTr';
            const isCompleted = !isTailColumn && chainState.completedIds.has(item.id);
            const expectedItemId = getExpectedItemId(key);
            const isPassed = expectedItemId === item.id && chainState.passedKeys.has(key);
            const showStartMarker = key === 'headEn' && !isCompleted && chainState.activeChainId === null;

            const element = document.createElement('div');
            element.className = `pair-item chain-item ${langClass}`;
            element.dataset.itemId = String(item.id);
            element.dataset.key = key;
            element.dataset.chainMark = isCompleted ? '✓' : (isPassed || showStartMarker ? chainMarks[key] : '');
            element.textContent = item.text;

            if (showStartMarker) {
                element.classList.add('startable');
                element.addEventListener('pointerdown', event => startChain(event, item.id));
            }

            if (isPassed) {
                element.classList.add('in-chain');
            }

            if (isCompleted) {
                element.classList.add('matched');
            }

            if (isCompleted && chainState.chainCompletedNow) {
                element.classList.add('chain-complete');
            }

            column.appendChild(element);
        });
    }

    function updateTexts() {
        const completed = chainState.completedIds.size;
        const total = chainState.total;

        document.getElementById('chainSummaryText').textContent = `${completed} / ${total} zincir tamamlandı`;
        document.getElementById('headProgressText').textContent = `${completed} / ${total} zincir tamamlandı`;
        document.getElementById('tailProgressText').textContent = `${completed} / ${total} zincir tamamlandı`;
        document.getElementById('finalProgressText').textContent = `${completed} / ${total} zincir tamamlandı`;

        const status = document.getElementById('chainStatusText');
        if (!status) {
            return;
        }

        if (completed === total) {
            status.textContent = 'Tüm zincirler tamamlandı. Son kart yeşile döndü; istersen modu değiştirip yeniden oyna.';
            return;
        }

        if (chainState.activeChainId === null) {
            status.textContent = 'Soldaki İngilizce karttan başla. Doğru yolu kendin bul ve sürüklemeyi son karta kadar bırakma.';
            return;
        }

        status.textContent = 'Zincir açık. Parmağı veya mouse tuşunu bırakmadan doğru kutuları sırayla bul.';
    }

    function updateChainOverlay() {
        const overlay = document.getElementById('chainOverlay');
        const grid = document.querySelector('.modules-grid');
        if (!overlay || !grid) {
            return;
        }

        const rect = grid.getBoundingClientRect();
        overlay.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
        overlay.innerHTML = '';

        if (chainState.activeChainId === null) {
            return;
        }

        const activeKeys = sequenceKeys.filter(key => chainState.passedKeys.has(key));
        const points = activeKeys
            .map(key => {
                const expectedItemId = getExpectedItemId(key);
                const element = document.querySelector(`.chain-item[data-item-id='${expectedItemId}'][data-key='${key}']`);
                if (!element) {
                    return null;
                }

                const itemRect = element.getBoundingClientRect();
                return {
                    x: itemRect.left + (itemRect.width / 2) - rect.left,
                    y: itemRect.top + (itemRect.height / 2) - rect.top
                };
            })
            .filter(Boolean);

        if (chainState.pointerPosition) {
            points.push(chainState.pointerPosition);
        }

        for (let index = 1; index < points.length; index++) {
            const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            line.setAttribute('x1', points[index - 1].x);
            line.setAttribute('y1', points[index - 1].y);
            line.setAttribute('x2', points[index].x);
            line.setAttribute('y2', points[index].y);
            line.setAttribute('stroke', '#ffa000');
            line.setAttribute('stroke-width', '5');
            line.setAttribute('stroke-linecap', 'round');
            line.setAttribute('stroke-dasharray', index === points.length - 1 ? '10 10' : '0');
            overlay.appendChild(line);
        }

        points.slice(0, Math.max(points.length - 1, 1)).forEach(point => {
            const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            circle.setAttribute('cx', point.x);
            circle.setAttribute('cy', point.y);
            circle.setAttribute('r', '10');
            circle.setAttribute('fill', '#ffffff');
            circle.setAttribute('stroke', '#ffa000');
            circle.setAttribute('stroke-width', '4');
            overlay.appendChild(circle);
        });
    }

    function renderAll() {
        const isModalMode = isVerbMode && currentTenseId === MODAL_TENSE_ID;
        const isWhQuestionsMode = isVerbMode && currentTenseId === WH_TENSE_ID;
        setVerbPanelsVisibility(true);
        const modalsArea = document.getElementById('modalsArea');
        const whQuestionsArea = document.getElementById('whQuestionsArea');
        if (modalsArea) {
            modalsArea.classList.toggle('hidden', !isModalMode);
        }
        if (whQuestionsArea) {
            whQuestionsArea.classList.toggle('hidden', !isWhQuestionsMode);
        }

        const status = document.getElementById('chainStatusText');
        if (status && isModalMode) {
            status.textContent = 'Modal kartlarini soldan baslayarak zincir mantigiyla eslestir.';
        }

        document.getElementById('tailSubtitle').textContent = isModalMode
            ? 'Modal kalibi + cümle devamı'
            : isWhQuestionsMode
                ? (currentWhGroup === 'negative' ? 'Olumsuz W-soru + cümle devamı' : 'Olumlu W-soru + cümle devamı')
            : (mode === 'singular'
                ? 'Tekil noun ile cümlenin arka parçası'
                : 'Çoğul noun ile cümlenin arka parçası');

        renderColumn('headEnglishCol', 'headEn', 'en');
        if (!isVerbMode) {
            renderColumn('headTurkishCol', 'headTr', 'tr');
        }
        renderColumn('tailEnglishCol', 'tailEn', 'en');
        if (!isVerbMode) {
            renderColumn('tailTurkishCol', 'tailTr', 'tr');
        }
        renderColumn('finalTurkishCol', 'finalTr', 'tr');
        updateTexts();
        requestAnimationFrame(updateChainOverlay);
        chainState.chainCompletedNow = false;
    }

    function getPointerPosition(event) {
        const grid = document.querySelector('.modules-grid');
        if (!grid) {
            return null;
        }

        const rect = grid.getBoundingClientRect();
        return {
            x: event.clientX - rect.left,
            y: event.clientY - rect.top
        };
    }

    function resetActiveChain() {
        chainState.activeChainId = null;
        chainState.passedKeys = new Set();
        chainState.pointerId = null;
        chainState.pointerPosition = null;
        document.body.classList.remove('chain-dragging');
        renderAll();
    }

    function completeActiveChain() {
        chainState.completedIds.add(chainState.activeChainId);
        chainState.chainCompletedNow = true;
        chainState.activeChainId = null;
        chainState.passedKeys = new Set();
        chainState.pointerId = null;
        chainState.pointerPosition = null;
        document.body.classList.remove('chain-dragging');
        renderAll();
    }

    function startChain(event, chainId) {
        if (chainState.completedIds.has(chainId) || chainState.activeChainId !== null) {
            return;
        }

        event.preventDefault();
        chainState.activeChainId = chainId;
        chainState.pointerId = event.pointerId;
        chainState.passedKeys = new Set(['headEn']);
        chainState.pointerPosition = getPointerPosition(event);
        document.body.classList.add('chain-dragging');
        renderAll();
    }

    function handlePointerMove(event) {
        if (chainState.activeChainId === null || chainState.pointerId !== event.pointerId) {
            return;
        }

        chainState.pointerPosition = getPointerPosition(event);

        const nextKey = sequenceKeys[chainState.passedKeys.size];
        if (!nextKey) {
            updateChainOverlay();
            return;
        }

        const hovered = document.elementFromPoint(event.clientX, event.clientY)?.closest('.chain-item');
        if (!hovered) {
            updateChainOverlay();
            return;
        }

        const expectedItemId = getExpectedItemId(nextKey);
        const hoveredKey = hovered.dataset.key;
        const hoveredId = Number.parseInt(hovered.dataset.itemId || '', 10);

        if (hoveredId !== expectedItemId || hoveredKey !== nextKey) {
            updateChainOverlay();
            return;
        }

        chainState.passedKeys.add(nextKey);

        if (nextKey === 'finalTr') {
            completeActiveChain();
            return;
        }

        renderAll();
    }

    function handlePointerEnd(event) {
        if (chainState.activeChainId === null || chainState.pointerId !== event.pointerId) {
            return;
        }

        resetActiveChain();
    }

    let chains = isVerbMode ? buildVerbSentenceChains() : buildSentenceChains(mode);
    let boardOrder = isVerbMode ? buildVerbBoardOrder(chains) : makeBoardOrder(chains);
    let chainState = createChainState(chains.length);

    function setMode(nextMode) {
        mode = nextMode;
        const singularButton = document.getElementById('modeSingularBtn');
        const pluralButton = document.getElementById('modePluralBtn');
        if (singularButton && pluralButton) {
            singularButton.classList.toggle('active', mode === 'singular');
            pluralButton.classList.toggle('active', mode === 'plural');
        }

        chains = isVerbMode ? buildVerbSentenceChains() : buildSentenceChains(mode);
        boardOrder = isVerbMode ? buildVerbBoardOrder(chains) : makeBoardOrder(chains);
        chainState = createChainState(chains.length);
        renderAll();
    }

    window.setMode = setMode;

    window.addEventListener('load', () => {
        window.addEventListener('pointermove', handlePointerMove);
        window.addEventListener('pointerup', handlePointerEnd);
        window.addEventListener('pointercancel', handlePointerEnd);
        window.addEventListener('resize', updateChainOverlay);
        renderAll();
        
        const tenseTabNav = document.querySelector('.tense-tabs-nav');
        if (tenseTabNav && !isVerbMode) {
            tenseTabNav.style.display = 'none';
        }

        const modalsArea = document.getElementById('modalsArea');
        if (modalsArea && !isVerbMode) {
            modalsArea.style.display = 'none';
        }

        const whQuestionsArea = document.getElementById('whQuestionsArea');
        if (whQuestionsArea && !isVerbMode) {
            whQuestionsArea.style.display = 'none';
        }

        const modalGroups = document.getElementById('modalGroups');
        if (modalGroups && !isVerbMode) {
            modalGroups.style.display = 'none';
        }

        // Setup Tab Listeners (VERB MODE ONLY)
        if (isVerbMode) {
            document.querySelectorAll('.tense-tab-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const tenseId = parseInt(e.currentTarget.dataset.tense);
                    currentTenseId = tenseId;
                    
                    // Update active tab
                    document.querySelectorAll('.tense-tab-btn').forEach(b => b.classList.remove('active'));
                    e.currentTarget.classList.add('active');

                    if (currentTenseId === MODAL_TENSE_ID) {
                        chains = buildModalSentenceChains();
                        boardOrder = buildModalBoardOrder(chains);
                        chainState = createChainState(chains.length);
                        renderAll();
                        return;
                    }

                    if (currentTenseId === WH_TENSE_ID) {
                        chains = buildVerbSentenceChains();
                        boardOrder = buildVerbBoardOrder(chains);
                        chainState = createChainState(chains.length);
                        renderAll();
                        return;
                    }
                    
                    // Rebuild and re-render
                    chains = buildVerbSentenceChains();
                    boardOrder = buildVerbBoardOrder(chains);
                    chainState = createChainState(chains.length);
                    renderAll();
                });
            });

            document.querySelectorAll('.modal-group-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    currentModalGroup = e.currentTarget.dataset.modalGroup;
                    document.querySelectorAll('.modal-group-btn').forEach(b => b.classList.remove('active'));
                    e.currentTarget.classList.add('active');

                    if (currentTenseId !== MODAL_TENSE_ID) {
                        return;
                    }

                    chains = buildModalSentenceChains();
                    boardOrder = buildModalBoardOrder(chains);
                    chainState = createChainState(chains.length);
                    renderAll();
                });
            });

            document.querySelectorAll('.wh-group-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    currentWhGroup = e.currentTarget.dataset.whGroup;
                    document.querySelectorAll('.wh-group-btn').forEach(b => b.classList.remove('active'));
                    e.currentTarget.classList.add('active');

                    if (currentTenseId !== WH_TENSE_ID) {
                        return;
                    }

                    chains = buildVerbSentenceChains();
                    boardOrder = buildVerbBoardOrder(chains);
                    chainState = createChainState(chains.length);
                    renderAll();
                });
            });
        }
    });
</script>
}