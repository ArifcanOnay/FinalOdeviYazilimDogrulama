            ],
            wh: [
                { en: 'What can he play to practice pronunciation?', tr: 'Telaffuz calismak icin ne calabilir?' },
                { en: 'Where could he play without disturbing anyone?', tr: 'Kimseyi rahatsiz etmeden nerede calabilir?' },
