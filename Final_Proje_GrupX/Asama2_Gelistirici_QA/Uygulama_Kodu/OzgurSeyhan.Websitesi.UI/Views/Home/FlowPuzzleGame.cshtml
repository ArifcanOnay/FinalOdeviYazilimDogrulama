    };
    let currentTenseId = 0;  // Start with first tense (Simple Present)

    const NEGATIVE_AUX_REPLACEMENTS = {
        am: 'are not',
        is: "isn't",
        are: "aren't",
        was: "wasn't",
        were: "weren't",
        do: "don't",
        does: "doesn't",
        did: "didn't",
        have: "haven't",
        has: "hasn't",
        had: "hadn't",
        will: "won't",
        can: "can't",
        could: "couldn't",
        would: "wouldn't",
        should: "shouldn't",
        may: 'may not',
        might: 'might not',
        must: 'must not'
    };

    function makeNegativeQuestionHead(headText) {
        let text = (headText || '').trim();
        if (!text) {
            return text;
        }

        text = text
            .replace(/\bam\s+i\s+not\b/gi, 'are not I')
            .replace(/\bam\s+not\s+i\b/gi, 'are not I');

        const tokens = text.split(/\s+/);
        if (tokens.length >= 3) {
            const whWords = new Set(['what', 'where', 'when', 'why', 'how', 'who', 'which']);
            const first = (tokens[0] || '').toLowerCase();
            const aux = (tokens[1] || '').toLowerCase();
            const subject = tokens[2] || '';
            const tail = tokens.slice(3).join(' ');

            if (whWords.has(first) && NEGATIVE_AUX_REPLACEMENTS[aux]) {
                if (aux === 'may' || aux === 'might') {
                    const rest = tail ? `${tail}` : '';
                    return `${tokens[0]} ${tokens[1]} ${subject} not ${rest}`.replace(/\s+/g, ' ').trim();
                }

                const replacement = NEGATIVE_AUX_REPLACEMENTS[aux];
                const rest = tail ? `${tail}` : '';
                return `${tokens[0]} ${replacement} ${subject} ${rest}`.replace(/\s+/g, ' ').trim();
            }
        }

        const auxIndex = tokens.findIndex((token, index) => index > 0 && NEGATIVE_AUX_REPLACEMENTS[token.toLowerCase()]);
        if (auxIndex === -1) {
            return text;
        }

        const replacement = NEGATIVE_AUX_REPLACEMENTS[tokens[auxIndex].toLowerCase()];
        tokens.splice(auxIndex, 1, ...replacement.split(' '));
        return tokens.join(' ');
    }

    function makeNegativeTurkishWh(text) {
        let value = (text || '').trim();
        if (!value) {
            return value;
        }

        value = value.replace(/\s*\(olumsuz\)\s*/gi, ' ').replace(/\s+/g, ' ').trim();
        const hadQuestion = /\?$/.test(value);
        value = value.replace(/\?$/, '').trim();

        const wholeSentenceDirect = [
            [/\bneredeydim$/i, 'nerede degildim'],
            [/\bneredeydik$/i, 'nerede degildik'],
            [/\bburadayim$/i, 'burada degilim'],
            [/\bburadayiz$/i, 'burada degiliz'],
            [/\byasamistim$/i, 'yasamamistim'],
            [/\bolacagim$/i, 'olmayacagim'],
            [/\bolacagiz$/i, 'olmayacagiz']
        ];

        for (const [pattern, replacement] of wholeSentenceDirect) {
            if (pattern.test(value)) {
                const out = value.replace(pattern, replacement).replace(/\s+/g, ' ').trim();
                return hadQuestion ? `${out}?` : out;
            }
        }

        const words = value.split(' ').filter(Boolean);
        if (words.length === 0) {
            return hadQuestion ? `${value}?` : value;
        }

        const applyPredicateNegation = (word) => {
            let w = (word || '').trim();
            if (!w) {
                return w;
            }

            const direct = [
                [/^gidebilirim$/i, 'gidemem'],
                [/^gidiyorum$/i, 'gitmiyorum'],
                [/^gittim$/i, 'gitmedim'],
                [/^gidiyordum$/i, 'gitmiyordum'],
                [/^gidecegim$/i, 'gitmeyecegim'],
                [/^gitmistim$/i, 'gitmemistim'],
                [/^olabilir$/i, 'olmayabilir'],
                [/^olmali$/i, 'olmamali'],
                [/^zorundayim$/i, 'zorunda degilim'],
                [/^zorundayiz$/i, 'zorunda degiliz']
            ];

            for (const [pattern, replacement] of direct) {
                if (pattern.test(w)) {
                    return replacement;
                }
            }

            const endingReplacements = [
                [/([a-z]+)maliyim$/i, '$1mamaliyim'],
                [/([a-z]+)meliyim$/i, '$1memeliyim'],
                [/([a-z]+)malilar$/i, '$1mamalilar'],
                [/([a-z]+)meliler$/i, '$1memeliler'],
                [/([a-z]+)mali$/i, '$1mamali'],
                [/([a-z]+)meli$/i, '$1memeli'],
                [/([a-z]+)abilirlerdi$/i, '$1amazlardi'],
                [/([a-z]+)ebilirlerdi$/i, '$1emezlerdi'],
                [/([a-z]+)abilirdi$/i, '$1amazdi'],
                [/([a-z]+)ebilirdi$/i, '$1emezdi'],
                [/([a-z]+)abilirler$/i, '$1amazlar'],
                [/([a-z]+)ebilirler$/i, '$1emezler'],
                [/([a-z]+)abilirim$/i, '$1amam'],
                [/([a-z]+)ebilirim$/i, '$1emem'],
                [/([a-z]+)abilir$/i, '$1amaz'],
                [/([a-z]+)ebilir$/i, '$1emez'],
                [/([a-z]+)iyordum$/i, '$1miyordum'],
                [/([a-z]+)iyordu$/i, '$1miyordu'],
                [/([a-z]+)acagim$/i, '$1mayacagim'],
                [/([a-z]+)ecegim$/i, '$1meyecegim'],
                [/([a-z]+)acaklar$/i, '$1mayacaklar'],
                [/([a-z]+)ecekler$/i, '$1meyecekler'],
                [/([a-z]+)acak$/i, '$1mayacak'],
                [/([a-z]+)ecek$/i, '$1meyecek'],
                [/([a-z]+)mistim$/i, '$1mamistim'],
                [/([a-z]+)ardim$/i, '$1mazdim'],
                [/([a-z]+)erdim$/i, '$1mezdim'],
                [/([a-z]+)ardi$/i, '$1mazdi'],
                [/([a-z]+)erdi$/i, '$1mezdi'],
                [/([a-z]+)iyorum$/i, '$1miyorum'],
                [/([a-z]+)iyor$/i, '$1miyor']
            ];

            for (const [pattern, replacement] of endingReplacements) {
                if (pattern.test(w)) {
                    return w.replace(pattern, replacement);
                }
            }

            return w;
        };

        // Handle two-word predicate chunks like "yapmak zorundalardi".
        if (words.length >= 2) {
            const lastTwo = `${words[words.length - 2]} ${words[words.length - 1]}`;
            if (/^([a-z]+)mak zorundalardi$/i.test(lastTwo)) {
                words[words.length - 2] = words[words.length - 2].replace(/mak$/i, 'mamak');
                const out = words.join(' ').replace(/\s+/g, ' ').trim();
                return hadQuestion ? `${out}?` : out;
            }

            if (/^([a-z]+)mek zorundalardi$/i.test(lastTwo)) {
                words[words.length - 2] = words[words.length - 2].replace(/mek$/i, 'memek');
                const out = words.join(' ').replace(/\s+/g, ' ').trim();
                return hadQuestion ? `${out}?` : out;
            }

            if (/^([a-z]+)mak zorunda$/i.test(lastTwo)) {
                words[words.length - 2] = words[words.length - 2].replace(/mak$/i, 'mamak');
                const out = words.join(' ').replace(/\s+/g, ' ').trim();
                return hadQuestion ? `${out}?` : out;
            }

            if (/^([a-z]+)mek zorunda$/i.test(lastTwo)) {
                words[words.length - 2] = words[words.length - 2].replace(/mek$/i, 'memek');
                const out = words.join(' ').replace(/\s+/g, ' ').trim();
                return hadQuestion ? `${out}?` : out;
            }
        }

        const lastIndex = words.length - 1;
        const transformedLast = applyPredicateNegation(words[lastIndex]);
        words[lastIndex] = transformedLast;

        let converted = words.join(' ').replace(/\s+/g, ' ').trim();

        // Never leave a bare "degil" at sentence end; negate predicate instead.
        if (/\bdegil$/i.test(converted)) {
            const parts = converted.split(' ').filter(Boolean);
            parts.pop();

            if (parts.length > 0) {
                const idx = parts.length - 1;
                const negated = applyPredicateNegation(parts[idx]);
                if (negated !== parts[idx]) {
                    parts[idx] = negated;
                } else {
                    parts[idx] = `${parts[idx]} olmaz`;
                }
            }

            converted = parts.join(' ').replace(/\s+/g, ' ').trim();
        }

        if (converted === value) {
            const fallbackWords = value.split(' ').filter(Boolean);
            if (fallbackWords.length > 0) {
                const idx = fallbackWords.length - 1;
                fallbackWords[idx] = applyPredicateNegation(fallbackWords[idx]);
                converted = fallbackWords.join(' ').replace(/\s+/g, ' ').trim();
            }

            if (!converted || converted === value) {
                converted = `${value} olmaz`;
            }
        }

        return hadQuestion ? `${converted}?` : converted;
    }

    function buildNegativeWhSentences(sentences) {
        return (sentences || []).map(sentence => ({
            ...sentence,
            preposition: makeNegativeQuestionHead(sentence.preposition),
            trSing: makeNegativeTurkishWh(sentence.trSing),
            trPlural: makeNegativeTurkishWh(sentence.trPlural || sentence.trSing)
        }));
    }

    const sequenceKeys = isVerbMode
        ? ['headEn', 'tailEn', 'finalTr']
        : ['headEn', 'headTr', 'tailEn', 'tailTr', 'finalTr'];
    const chainMarks = isVerbMode
        ? {
