@model List<OzgurSeyhan.Websitesi.UI.Controllers.FlowPuzzleSentenceDto>
@{
    ViewData["Title"] = "Cümlenin Arkası - Fiiller";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentNoun = ViewBag.CurrentNoun as OzgurSeyhan.Websitesi.UI.Controllers.FlowPuzzleNounDto;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .flow-container {
        max-width: 1600px;
        margin: 20px auto;
        padding: 20px;
    }

    .game-header {
        text-align: center;
        color: white;
        margin-bottom: 18px;
    }

    .game-header h1 {
        font-size: 2.6rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .game-header p {
        font-size: 1.05rem;
        opacity: 0.95;
    }

    .current-noun-display {
        background: white;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.25);
        text-align: center;
    }

    .current-noun-display h2 {
        color: #5a63d8;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .mode-switch {
        display: inline-flex;
        gap: 10px;
        background: #eef2ff;
        border-radius: 999px;
        padding: 6px;
    }

    .mode-btn {
        border: none;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s ease;
        background: transparent;
        color: #4b4f8c;
    }

    .mode-btn.active {
        background: #4b55d6;
        color: #fff;
    }

    .chain-status {
        margin-top: 14px;
        font-size: 0.96rem;
        font-weight: 700;
        color: #45506e;
    }

    .chain-summary {
        margin-top: 8px;
        font-size: 0.92rem;
        font-weight: 700;
        color: #4b55d6;
    }

    .modules-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1.2fr;
        gap: 18px;
        margin-bottom: 20px;
        position: relative;
    }

    .chain-overlay {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
        z-index: 10;
    }

    .module-card {
        background: white;
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.25);
        position: relative;
        z-index: 2;
    }

    .module-title {
        font-size: 1.25rem;
        font-weight: 800;
        margin-bottom: 6px;
        text-align: center;
    }

    .module-title.left { color: #1d68be; }
    .module-title.middle { color: #8e44ad; }
    .module-title.right { color: #0d8a61; }

    .module-subtitle {
        text-align: center;
        color: #666;
        font-size: 0.88rem;
        margin-bottom: 12px;
        min-height: 44px;
    }

    .pair-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        padding: 0 4px;
        position: relative;
        border-radius: 12px;
    }

    .pair-col {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .pair-col-title {
        text-align: center;
        font-size: 0.82rem;
        font-weight: 700;
        border-radius: 10px;
        padding: 6px;
    }

    .pair-col-title.en { background: #e3f2fd; color: #1565c0; }
    .pair-col-title.tr { background: #fce4ec; color: #ad1457; }

    .pair-item {
        border: 2px solid #ddd;
        border-radius: 10px;
        padding: 9px 10px;
        text-align: center;
        font-size: 0.86rem;
        font-weight: 600;
        cursor: pointer;
        user-select: none;
        touch-action: none;
        transition: all .2s ease;
        line-height: 1.35;
        position: relative;
        min-height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pair-item:hover:not(.matched) {
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
    }

    .pair-item.en { background: #eef6ff; color: #1a5ea5; border-color: #9dc6f6; }
    .pair-item.tr { background: #fff1f6; color: #b71c59; border-color: #f7b9d2; }

    .pair-item.startable {
        box-shadow: inset 0 0 0 1px rgba(90, 99, 216, 0.35);
    }

    .pair-item.in-chain {
        border-color: #ffa000 !important;
        background: #fff3cd !important;
        color: #8a5b00 !important;
    }

    .pair-item.matched {
        background: #e8f5e9 !important;
        border-color: #66bb6a !important;
        color: #2e7d32 !important;
        cursor: default;
        pointer-events: none;
    }

    .pair-item.chain-complete {
        animation: chainGlow .55s ease;
    }

    .pair-item.startable::after,
    .pair-item.in-chain::after,
    .pair-item.matched::after {
        content: attr(data-chain-mark);
        position: absolute;
        top: -12px;
        right: -12px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.82rem;
        font-weight: 800;
        background: white;
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
    }

    .pair-item.startable::after {
        border: 2px solid #5a63d8;
        color: #5a63d8;
    }

    .pair-item.in-chain::after {
        border: 2px solid #ffa000;
        color: #b06a00;
    }

    .pair-item.matched::after {
        border: 2px solid #66bb6a;
        color: #2e7d32;
    }

    .module-progress {
        margin-top: 12px;
        text-align: center;
        font-weight: 700;
        color: #4b3fbf;
        font-size: 0.9rem;
    }

    .pagination-controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin-top: 6px;
    }

    .tense-tabs-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        margin-bottom: 20px;
    }

    .tense-tab-btn {
        padding: 10px 16px;
        font-size: 0.9rem;
        font-weight: 700;
        border: 2px solid white;
        border-radius: 10px;
        cursor: pointer;
        transition: all .2s ease;
        background: transparent;
        color: white;
    }

    .tense-tab-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
    }

    .tense-tab-btn.active {
        background: white;
        color: #667eea;
        border-color: white;
    }

    .modals-area {
        margin: -4px 0 20px;
        padding: 16px;
        border-radius: 15px;
        background: rgba(255, 255, 255, 0.13);
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: white;
        text-align: center;
    }

    .modals-area.hidden {
        display: none;
    }

    .modals-title {
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .modals-chips {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .modal-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.45);
        color: #fff;
    }

    .modals-note {
        margin-top: 10px;
        font-size: 0.88rem;
        opacity: 0.92;
    }

    .modal-groups {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .modal-group-btn {
        border: 1px solid rgba(255, 255, 255, 0.45);
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s ease;
    }

    .modal-group-btn.active {
        background: #fff;
        color: #5963d6;
        border-color: #fff;
    }

    .btn-page {
        padding: 10px 20px;
        font-size: 0.95rem;
        font-weight: 700;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: all .2s ease;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        text-decoration: none;
    }

    .btn-page:hover:not(.disabled) {
        transform: translateY(-1px);
        color: white;
    }

    .btn-page.disabled {
        opacity: .5;
        pointer-events: none;
    }

    .page-info {
        color: white;
        font-size: 1rem;
        font-weight: 700;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,0.2);
    }

    body.chain-dragging {
        cursor: grabbing;
    }

    @@keyframes chainGlow {
        0% {
            box-shadow: 0 0 0 rgba(102, 187, 106, 0);
            transform: scale(1);
        }

        45% {
            box-shadow: 0 0 0 10px rgba(102, 187, 106, 0.18);
            transform: scale(1.03);
        }

        100% {
            box-shadow: 0 0 0 rgba(102, 187, 106, 0);
            transform: scale(1);
        }
    }

    @@media (max-width: 1200px) {
        .modules-grid {
            grid-template-columns: 1fr;
        }

    }
</style>

<div class="flow-container">
    <div class="game-header">
        <h1><i class="fas fa-graduation-cap me-2"></i>Fiil Öğrenme Oyunu</h1>
        <p>Solda fiil kalıbı, ortada cümle devamı, sağda tam Türkçe çeviri ile fiilleri pekiştir.</p>
    </div>

    @if (currentNoun != null && Model != null && Model.Any())
    {
        <div class="current-noun-display">
            <h2>@currentNoun.TurkishMeaning</h2>
            <div class="chain-status" id="chainStatusText">Soldaki İngilizce karttan başla. Doğru yolu kendin bul ve sürüklemeyi son karta kadar bırakma.</div>
            <div class="chain-summary" id="chainSummaryText">Tüm cümleler (@Model.Count)</div>
        </div>

        <!-- TABS NAV -->
        <div class="tense-tabs-nav">
            <button class="tense-tab-btn active" data-tense="0">1. Simple Present</button>
            <button class="tense-tab-btn" data-tense="1">2. Present Continuous</button>
            <button class="tense-tab-btn" data-tense="2">3. Simple Past</button>
            <button class="tense-tab-btn" data-tense="3">4. Past Continuous</button>
            <button class="tense-tab-btn" data-tense="4">5. Simple Future</button>
            <button class="tense-tab-btn" data-tense="5">6. Present Perfect</button>
            <button class="tense-tab-btn" data-tense="6">7. Past Perfect</button>
            <button class="tense-tab-btn" data-tense="7">8. WH-Questions</button>
            <button class="tense-tab-btn" data-tense="8">9. Modal Verbs</button>
        </div>

        <div class="modals-area hidden" id="modalsArea">
            <div class="modals-title">9. Modal Verbs</div>
            <div class="modals-chips">
                <span class="modal-chip">can</span>
                <span class="modal-chip">could</span>
                <span class="modal-chip">would</span>
                <span class="modal-chip">should</span>
                <span class="modal-chip">may</span>
                <span class="modal-chip">might</span>
                <span class="modal-chip">must</span>
            </div>
            <div class="modals-note" id="modalsNote">9. sekmede eşleştirme oyunu modal cümlelerle devam eder.</div>
            <div class="modal-groups" id="modalGroups">
                <button class="modal-group-btn active" data-modal-group="affirmative">A) Olumlu</button>
                <button class="modal-group-btn" data-modal-group="negative">B) Olumsuz</button>
                <button class="modal-group-btn" data-modal-group="yesNo">C) Soru</button>
                <button class="modal-group-btn" data-modal-group="wh">D) W-Soru</button>
            </div>
        </div>

        <div class="modals-area hidden" id="whQuestionsArea">
            <div class="modals-title">8. WH-Questions</div>
            <div class="modals-chips">
                <span class="modal-chip">who</span>
                <span class="modal-chip">what</span>
                <span class="modal-chip">where</span>
                <span class="modal-chip">when</span>
                <span class="modal-chip">why</span>
                <span class="modal-chip">how</span>
            </div>
            <div class="modals-note">W-Soru sekmesinde olumlu ve olumsuz soru gruplari ayri oynanir.</div>
            <div class="modal-groups" id="whGroups">
                <button class="modal-group-btn wh-group-btn active" data-wh-group="affirmative">A) Olumlu W-Soru</button>
                <button class="modal-group-btn wh-group-btn" data-wh-group="negative">B) Olumsuz W-Soru</button>
            </div>
        </div>

        <div class="modules-grid">
            <svg class="chain-overlay" id="chainOverlay" aria-hidden="true"></svg>

            <div class="module-card">
                <div class="module-title left">Cümlenin Başı</div>
                <div class="module-subtitle">Seçilen tense için 3 form (olumlu, olumsuz, soru)</div>
                <div class="pair-grid" style="grid-template-columns: 1fr;">
                    <div class="pair-col" id="headEnglishCol">
                        <div class="pair-col-title en">İngilizce</div>
                    </div>
                </div>
                <div class="module-progress" id="headProgressText">Başlangıç halkası buradan açılır</div>
            </div>

            <div class="module-card">
                <div class="module-title middle">Cümlenin Arkası</div>
                <div class="module-subtitle" id="tailSubtitle">Fiil kalıbı + cümle devamı</div>
                <div class="pair-grid" style="grid-template-columns: 1fr;">
                    <div class="pair-col" id="tailEnglishCol">
                        <div class="pair-col-title en">İngilizce</div>
                    </div>
                </div>
                <div class="module-progress" id="tailProgressText">Zincirin orta halkaları burada</div>
            </div>

            <div class="module-card">
                <div class="module-title right">Tam Cümle Çevirisi</div>
                <div class="module-subtitle">Baş + Arka birleşimi: sadece Türkçe anlam ile doğru cevabı bul</div>
                <div class="pair-grid" style="grid-template-columns: 1fr;">
                    <div class="pair-col" id="finalTurkishCol">
                        <div class="pair-col-title tr">Tam Türkçe</div>
                    </div>
                </div>
                <div class="module-progress" id="finalProgressText">Son halkada tüm zincir yeşile döner</div>
            </div>
        </div>

        <div class="pagination-controls">
            <a href="@Url.Action("FlowPuzzleGame", "Home", new { page = currentPage - 1 })"
               class="btn-page @(currentPage <= 1 ? "disabled" : "")">
                <i class="fas fa-chevron-left"></i> Önceki
            </a>
            <span class="page-info">@currentPage / @totalPages</span>
            <a href="@Url.Action("FlowPuzzleGame", "Home", new { page = currentPage + 1 })"
               class="btn-page @(currentPage >= totalPages ? "disabled" : "")">
                Sonraki <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    }
</div>

@if (Model != null && Model.Any())
{
<script>
    const rawSentences = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Select(s => new
        {
            id = s.Id,
            displayOrder = s.DisplayOrder,
            preposition = s.Preposition,
            detSing = s.DeterminerSingular,
            detPlural = s.DeterminerPlural,
            nounSing = s.NounSingular,
            nounPlural = s.NounPlural,
            trSing = s.TurkishSingular,
            trPlural = s.TurkishPlural
        })));

    const currentNounEn = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((currentNoun?.SingularForm ?? string.Empty).ToLowerInvariant()));
    const isVerbMode = detectVerbMode(rawSentences);
    const MODAL_TENSE_ID = 8;
    const WH_TENSE_ID = 7;
    let currentModalGroup = 'affirmative';
    let currentWhGroup = 'affirmative';

    const WHO_W_QUESTION_BY_VERB = {
        be: { head: 'Who is he', tail: 'with at the event?', tr: 'Etkinlikte kimle birlikte?' },
        have: { head: 'Who does she have', tail: 'lunch with on Fridays?', tr: 'Cuma gunleri kiminle ogle yemegi yer?' },
        do: { head: 'Who do they', tail: 'do this task with?', tr: 'Bu gorevi kiminle yaparlar?' },
        say: { head: 'Who do I', tail: 'say this to first?', tr: 'Bunu once kime soylerim?' },
        get: { head: 'Who do we', tail: 'get help from in this office?', tr: 'Bu ofiste kimden yardim aliriz?' },
        make: { head: 'Who do you', tail: 'make this plan with?', tr: 'Bu plani kiminle yaparsin?' },
        see: { head: 'Who do I', tail: 'see about this issue?', tr: 'Bu konu icin kimi gorurum?' },
        know: { head: 'Who does she', tail: 'know in that company?', tr: 'O sirkette kimi taniyor?' },
        take: { head: 'Who does he', tail: 'take to the station?', tr: 'Istasyona kimi goturur?' },
        give: { head: 'Who do they', tail: 'give priority to?', tr: 'Kime oncelik verirler?' },
        find: { head: 'Who do we', tail: 'find reliable in this team?', tr: 'Bu ekipte kimi guvenilir buluruz?' },
        think: { head: 'Who do I', tail: 'think can solve this quickly?', tr: 'Bunu hizlica kimin cozebilecegini dusunuyorum?' },
        tell: { head: 'Who do you', tail: 'tell the news to first?', tr: 'Haberi once kime verirsin?' },
        become: { head: 'Who does he', tail: 'become close to over time?', tr: 'Zamanla kime yakinlasir?' },
        show: { head: 'Who does she', tail: 'show the draft to first?', tr: 'Taslagi once kime gosterir?' },
        leave: { head: 'Who do they', tail: 'leave the keys with?', tr: 'Anahtarlari kime birakirlar?' },
        feel: { head: 'Who do I', tail: 'feel safest with?', tr: 'Kendimi en guvende kimin yaninda hissederim?' },
        put: { head: 'Who does she', tail: 'put in charge of this task?', tr: 'Bu gorevin basina kimi koyar?' },
        bring: { head: 'Who do you', tail: 'bring to the workshop?', tr: 'Atolyeye kimi getirirsin?' },
        keep: { head: 'Who do I', tail: 'keep in the loop on this?', tr: 'Bu konuda kimi surekli haberdar tutarim?' },
        let: { head: 'Who does she', tail: 'let into the meeting room?', tr: 'Toplanti odasina kimi alir?' },
        begin: { head: 'Who do they', tail: 'begin this project with?', tr: 'Bu projeye kiminle baslarlar?' },
        seem: { head: 'Who does it', tail: 'seem most useful for?', tr: 'Bu en cok kime faydali gorunuyor?' },
        help: { head: 'Who do we', tail: 'help first in an emergency?', tr: 'Acil durumda once kime yardim ederiz?' },
        go: { head: 'Who do I', tail: 'go with on weekends?', tr: 'Hafta sonlari kiminle giderim?' },
        come: { head: 'Who does she', tail: 'come with to class?', tr: 'Derse kiminle gelir?' },
        talk: { head: 'Who do you', tail: 'talk to when you need advice?', tr: 'Tavsiyeye ihtiyacin oldugunda kiminle konusursun?' },
        turn: { head: 'Who does it', tail: 'turn to for support?', tr: 'Destek icin kime yonelir?' },
        start: { head: 'Who do we', tail: 'start this lesson with?', tr: 'Bu derse kiminle baslariz?' },
        play: { head: 'Who does he', tail: 'play against in the final?', tr: 'Finalde kime karsi oynar?' }
    };

    const WHO_MODAL_WH_BY_VERB = {
        be: { en: 'Who might he be with right now?', tr: 'Su an kimle birlikte olabilir?' },
        have: { en: 'Who may she have lunch with tomorrow?', tr: 'Yarin kiminle ogle yemegi yiyebilir?' },
        do: { en: 'Who should they do this task with?', tr: 'Bu gorevi kiminle yapmalilar?' },
        say: { en: 'Who should I say this to first?', tr: 'Bunu once kime soylemeliyim?' },
        get: { en: 'Who can we get support from quickly?', tr: 'Hizlica kimden destek alabiliriz?' },
        make: { en: 'Who could you make this project with?', tr: 'Bu projeyi kiminle yapabilirdin?' },
        see: { en: 'Who should I see about this problem?', tr: 'Bu sorun icin kimi gormeliyim?' },
        know: { en: 'Who might she know at this company?', tr: 'Bu sirkette kimi taniyor olabilir?' },
        take: { en: 'Who should he take to the appointment?', tr: 'Randevuya kimi goturmeli?' },
        give: { en: 'Who should they give this chance to?', tr: 'Bu firsati kime vermeliler?' },
        find: { en: 'Who might we find in the office now?', tr: 'Su an ofiste kimi bulabiliriz?' },
        think: { en: 'Who should I think about hiring?', tr: 'Kimi ise almayi dusunmeliyim?' },
        tell: { en: 'Who must you tell about this update?', tr: 'Bu guncellemeyi kime bildirmek zorundasin?' },
        become: { en: 'Who could he become friends with here?', tr: 'Burada kimle arkadas olabilir?' },
        show: { en: 'Who should she show the report to first?', tr: 'Raporu once kime gostermeli?' },
        leave: { en: 'Who might they leave the documents with?', tr: 'Belgeleri kime birakabilirler?' },
        feel: { en: 'Who can I feel comfortable speaking with?', tr: 'Kiminle konusurken rahat hissedebilirim?' },
        put: { en: 'Who should she put in charge today?', tr: 'Bugun gorevin basina kimi koymali?' },
        bring: { en: 'Who can you bring to the session?', tr: 'Oturuma kimi getirebilirsin?' },
        keep: { en: 'Who should I keep informed about this?', tr: 'Bu konuda kimi bilgilendirmeliyim?' },
        let: { en: 'Who may she let into the lab?', tr: 'Laboratuvara kimi alabilir?' },
        begin: { en: 'Who should they begin with in round one?', tr: 'Ilk turda kiminle baslamalilar?' },
        seem: { en: 'Who might it seem difficult for at first?', tr: 'Ilk basta kime zor gorunebilir?' },
        help: { en: 'Who should we help first today?', tr: 'Bugun once kime yardim etmeliyiz?' },
        go: { en: 'Who might I go with this weekend?', tr: 'Bu hafta sonu kiminle gidebilirim?' },
