        };

    let mode = 'singular';

    function detectVerbMode(sentences) {
        if (!Array.isArray(sentences) || sentences.length < 3) {
            return false;
        }

        const headLikeRegex = /^(i|you|he|she|it|we|they|am|is|are|was|were|will|do|does|did|have|has|had)\b/i;
        const headLikeCount = sentences.filter(s => headLikeRegex.test((s.preposition || '').trim())).length;
        return headLikeCount >= Math.ceil(sentences.length * 0.5);
    }

    function shuffle(arr) {
        const copy = [...arr];
        for (let i = copy.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [copy[i], copy[j]] = [copy[j], copy[i]];
        }
        return copy;
    }

    function getNounCategory(noun) {
        const value = (noun || '').toLowerCase().trim();
        const peopleLike = new Set(['child', 'student', 'teacher', 'person', 'man', 'woman', 'friend', 'doctor', 'nurse', 'patient']);
        const placeLike = new Set(['school', 'university', 'city', 'country', 'park', 'garden', 'building', 'room', 'street', 'hospital', 'bank', 'shop']);
        const foodLike = new Set(['food', 'drink', 'coffee', 'tea', 'milk', 'bread', 'egg', 'meat', 'fruit', 'vegetable', 'apple', 'banana', 'orange', 'tomato', 'potato', 'onion', 'water']);
        const animalLike = new Set(['dog', 'cat', 'bird', 'animal', 'fish']);

        if (peopleLike.has(value)) {
            return 'people';
        }

        if (placeLike.has(value)) {
            return 'place';
        }

        if (foodLike.has(value)) {
            return 'food';
        }

        if (animalLike.has(value)) {
            return 'animal';
        }

        return 'general';
    }

