@{
    ViewData["Title"] = "E-posta Dogrulama";
    Layout = null;

    bool verificationSuccess = ViewBag.VerificationSuccess is bool success && success;
    string verificationMessage = ViewBag.VerificationMessage as string ?? "Dogrulama sonucu alinamadi.";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/Site ana resim.png">
    <link rel="shortcut icon" type="image/png" href="~/Site ana resim.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: linear-gradient(135deg, #2e7d32 0%, #66bb6a 100%);
        }

        .verify-card {
            width: 100%;
            max-width: 560px;
            border-radius: 20px;
            background: #fff;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
            padding: 36px;
            text-align: center;
        }

        .status-icon {
            width: 82px;
            height: 82px;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #fff;
        }

        .status-icon.success {
            background: #2e7d32;
        }

        .status-icon.error {
            background: #d32f2f;
        }

        .verify-title {
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 10px;
        }

        .verify-message {
            color: #4b5563;
            margin-bottom: 26px;
            line-height: 1.6;
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            background: #2e7d32;
            color: #fff;
            font-weight: 600;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-action:hover {
            transform: translateY(-1px);
            color: #fff;
            box-shadow: 0 8px 20px rgba(46, 125, 50, 0.35);
        }

        .btn-secondary-link {
            display: inline-flex;
            margin-left: 10px;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 20px;
            border-radius: 10px;
            background: #f3f4f6;
            color: #111827;
            text-decoration: none;
            font-weight: 600;
        }

        .btn-secondary-link:hover {
            color: #111827;
            background: #e5e7eb;
        }

        @@media (max-width: 576px) {
            .verify-card {
                padding: 26px 20px;
            }

            .btn-secondary-link {
                margin-top: 10px;
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="verify-card">
        <div class="status-icon @(verificationSuccess ? "success" : "error")">
            <i class="fas @(verificationSuccess ? "fa-check" : "fa-times")"></i>
        </div>

        <h2 class="verify-title">@(verificationSuccess ? "E-posta Dogrulandi" : "Dogrulama Basarisiz")</h2>
        <p class="verify-message">@verificationMessage</p>

        <a class="btn-action" href="/Home/Login">
            <i class="fas fa-sign-in-alt"></i>
            Giris Sayfasina Git
        </a>
        <a class="btn-secondary-link" href="/Home/Register">
            <i class="fas fa-user-plus"></i>
            Kayit Sayfasina Don
        </a>
    </div>
</body>
</html>
