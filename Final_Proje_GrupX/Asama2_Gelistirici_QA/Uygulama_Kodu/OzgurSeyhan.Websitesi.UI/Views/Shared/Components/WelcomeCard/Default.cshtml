<div class="card">
    <div class="card-header">
        <h4 class="card-title">Hoşgeldiniz, Özgür Hoca! 👋</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 text-center">
                <img src="~/Ready-Bootstrap-Dashboard-master/assets/img/Özgür Hoca resim.jpg" 
                     alt="Özgür Seyhan" 
                     class="img-fluid rounded-circle" 
                     style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #1572e8;">
            </div>
            <div class="col-md-8">
                <h3>Özgür Seyhan</h3>
                <p class="text-muted">İngilizce Öğretmeni</p>
                <p>
                    Admin panelinize hoş geldiniz! Buradan tüm içeriklerinizi yönetebilir, 
                    <strong>"İngilizceni Geliştirecek Podcastler"</strong> bölümüne playlist ekleyebilir,
                    <strong>"Spotify Şarkıları"</strong> ekleyebilir ve özel derslerinizi düzenleyebilirsiniz.
                </p>
                <div class="mt-3">
                    <a href="@Url.Action("PlaylistIndex", "Youtube")" class="btn btn-primary btn-sm">
                        <i class="la la-podcast"></i> Podcast Yönetimi
                    </a>
                    <a href="@Url.Action("PodcastIndex", "Youtube")" class="btn btn-success btn-sm" style="background: #1DB954; border-color: #1DB954;">
                        <i class="fab fa-spotify"></i> Spotify Yönetimi
                    </a>
                    <a href="@Url.Action("Index", "OzelDers")" class="btn btn-warning btn-sm">
                        <i class="la la-book"></i> Özel Dersler
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
