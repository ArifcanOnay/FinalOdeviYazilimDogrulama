@model List<OzgurSeyhan.Websitesi.UI.Controllers.FlowPuzzleNounDto>
@{
    ViewData["Title"] = "Edat İsim Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-inner">
    <div class="page-header">
        <h4 class="page-title">Edat İsim Yönetimi</h4>
        <ul class="breadcrumbs">
            <li class="nav-home">
                <a href="@Url.Action("Index", "AdminLayout")">
                    <i class="flaticon-home"></i>
                </a>
            </li>
            <li class="separator">
                <i class="flaticon-right-arrow"></i>
            </li>
            <li class="nav-item">
                <a href="#">Edat İsimleri</a>
            </li>
        </ul>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex align-items-center">
                        <h4 class="card-title">Tekil/Çoğul İsim Çiftleri</h4>
                        <a href="@Url.Action("Create")" class="btn btn-primary btn-round ml-auto">
                            <i class="fa fa-plus"></i>
                            Yeni İsim Çifti Ekle
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Hata!</strong> @TempData["Error"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    <div class="table-responsive">
                        <table id="flowPuzzleTable" class="display table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tekil Form</th>
                                    <th>Çoğul Form</th>
                                    <th>Türkçe Anlam</th>
                                    <th>Aktif</th>
                                    <th>Sıra</th>
                                    <th style="width: 10%">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var noun in Model)
                                    {
                                        <tr>
                                            <td>@noun.Id</td>
                                            <td><strong>@noun.SingularForm</strong></td>
                                            <td><strong>@noun.PluralForm</strong></td>
                                            <td>@noun.TurkishMeaning</td>
                                            <td>
                                                @if (noun.IsActive)
                                                {
                                                    <span class="badge badge-success">Aktif</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Pasif</span>
                                                }
                                            </td>
                                            <td>@noun.DisplayOrder</td>
                                            <td>
                                                <div class="form-button-action">
                                                    <a href="@Url.Action("Edit", new { id = noun.Id })" class="btn btn-link btn-primary btn-lg" data-toggle="tooltip" title="Düzenle">
                                                        <i class="fa fa-edit"></i>
                                                    </a>
                                                    <form method="post" action="@Url.Action("Delete", new { id = noun.Id })" style="display: inline-block;">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-link btn-danger" data-toggle="tooltip" title="Sil" onclick="return confirm('Bu isim çiftini silmek istediğinize emin misiniz?');">
                                                            <i class="fa fa-times"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center">Henüz isim çifti eklenmemiş.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#flowPuzzleTable').DataTable({
                "pageLength": 10,
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Turkish.json"
                }
            });

            $('[data-toggle="tooltip"]').tooltip();
        });
    </script>
}
